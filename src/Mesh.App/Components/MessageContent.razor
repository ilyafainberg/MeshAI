@inject AppState State
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (Attachments is { Count: > 0 })
{
    <div class="message-attachments">
        @foreach (var attachment in Attachments.Where(a => a.IsImage))
        {
            <img class="msg-img attached-preview"
                 src="@DataUri(attachment)"
                 alt="@attachment.Name"
                 title="@attachment.Name"
                 @onclick="() => Download(attachment)" />
        }
    </div>
}

@foreach (var seg in Markdown.Parse(Text))
{
    if (seg.IsFile)
    {
        @if (seg.FileMime is not null && seg.FileMime.StartsWith("image/"))
        {
            <img class="msg-img" src="data:@seg.FileMime;base64,@seg.Content"
                 alt="@seg.FileName" title="@seg.FileName (click to save)"
                 @onclick="() => Download(seg)" />
        }
        else
        {
            <button class="file-card" @onclick="() => Download(seg)" title="Save @seg.FileName">
                <i class="bi bi-file-earmark-arrow-down"></i>
                <div class="app-card-text">
                    <b>@seg.FileName</b>
                    <small>@SizeLabel(seg.Content) · click to save</small>
                </div>
            </button>
        }
    }
    else if (!seg.IsApp)
    {
        @if (!string.IsNullOrWhiteSpace(seg.Content))
        {
            <div class="text md">@((MarkupString)Markdown.ToHtml(seg.Content))</div>
        }
    }
    else if (!State.Profile.AllowInteractiveApps)
    {
        <div class="app-card disabled">
            <i class="bi bi-window"></i>
            <div class="app-card-text"><b>Interactive app hidden</b><small>enable in Settings</small></div>
        </div>
    }
    else
    {
        var id = seg.Content.GetHashCode();
        appHtml[id] = seg.Content;
        @if (running.Contains(id))
        {
            <div class="app-frame widget-frame-host @(expanded.Contains(id) ? "expanded" : "")"
                 style="width:100%;max-width:100%;min-width:0;">
                <iframe @ref="frameRefs[id]"
                        sandbox="allow-scripts"
                        referrerpolicy="no-referrer"
                        style="min-width:0;max-width:100%;"></iframe>
                <div class="widget-render-status" hidden aria-live="polite"></div>
                <div class="app-toolbar">
                    @if (OnPin.HasDelegate)
                    {
                        <button @onclick="() => OnPin.InvokeAsync(seg.Content)" title="Pin as widget" aria-label="Pin as widget"><i class="bi bi-pin-angle"></i></button>
                    }
                    <button @onclick="() => Toggle(expanded, id)" title="@(expanded.Contains(id) ? "Shrink" : "Expand")" aria-label="@(expanded.Contains(id) ? "Shrink" : "Expand")">
                        <i class="bi @(expanded.Contains(id) ? "bi-arrows-angle-contract" : "bi-arrows-angle-expand")"></i>
                    </button>
                    <button @onclick="() => Close(id)" title="Close app" aria-label="Close app"><i class="bi bi-x-lg"></i></button>
                </div>
            </div>
        }
        else
        {
            <button class="app-card" @onclick="() => running.Add(id)">
                <i class="bi bi-play-circle"></i>
                <div class="app-card-text">
                    <b>Interactive app@(string.IsNullOrEmpty(From) ? "" : $" from {From}")</b>
                    <small>runs sandboxed · no access to your data · tap to run</small>
                </div>
            </button>
        }
    }
}

@code {
    [Parameter] public string Text { get; set; } = "";
    [Parameter] public IReadOnlyList<ChatAttachment>? Attachments { get; set; }
    [Parameter] public string? From { get; set; }
    [Parameter] public EventCallback<string> OnPin { get; set; }

    private readonly HashSet<int> running = new();
    private readonly HashSet<int> expanded = new();

    // Per-app iframe element (keyed by the app id) plus the HTML to load into it
    // and the set of frames whose content has already been set.
    private readonly Dictionary<int, ElementReference> frameRefs = new();
    private readonly Dictionary<int, string> appHtml = new();
    private readonly HashSet<int> mounted = new();

    private void Toggle(HashSet<int> set, int id)
    {
        if (!set.Remove(id)) set.Add(id);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Hand each freshly shown app to the secure loader once per mount.
        foreach (var id in running.ToList())
        {
            if (mounted.Contains(id)) continue;
            if (!frameRefs.TryGetValue(id, out var el)) continue;
            if (!appHtml.TryGetValue(id, out var html)) continue;
            try
            {
                await JS.InvokeVoidAsync("sandboxFrame.setFrameHtml", el, html);
                mounted.Add(id);
            }
            catch { /* frame not ready yet; retry on the next render */ }
        }
    }

    private async Task Close(int id)
    {
        // Clear the iframe content while it is still in the DOM, then remove it.
        if (frameRefs.TryGetValue(id, out var el))
        {
            try { await JS.InvokeVoidAsync("sandboxFrame.revokeFrame", el); }
            catch { /* ignore revoke failures */ }
        }
        mounted.Remove(id);
        frameRefs.Remove(id);
        running.Remove(id);
    }

    private async Task Download(MessageSegment seg)
    {
        try { await JS.InvokeVoidAsync("meshUI.downloadFile", seg.FileName, seg.FileMime, seg.Content); }
        catch { /* ignore download failures */ }
    }

    private async Task Download(ChatAttachment attachment)
    {
        try
        {
            await JS.InvokeVoidAsync("meshUI.downloadFile", attachment.Name, attachment.MimeType,
                Convert.ToBase64String(attachment.Data));
        }
        catch { /* ignore download failures */ }
    }

    private static string DataUri(ChatAttachment attachment)
        => $"data:{attachment.MimeType};base64,{Convert.ToBase64String(attachment.Data)}";

    private static string SizeLabel(string base64)
    {
        // Approximate decoded byte count from base64 length.
        long bytes = (long)(base64.Length * 3L / 4);
        string[] units = { "B", "KB", "MB", "GB" };
        double size = bytes;
        int u = 0;
        while (size >= 1024 && u < units.Length - 1) { size /= 1024; u++; }
        return $"{size:0.#} {units[u]}";
    }

    public async ValueTask DisposeAsync()
    {
        foreach (var frame in frameRefs.Values)
        {
            try { await JS.InvokeVoidAsync("sandboxFrame.revokeFrame", frame); }
            catch { }
        }
        frameRefs.Clear();
        mounted.Clear();
    }
}
