@inject AppState State
@inject MeshClient Mesh
@inject IQrScanner QrScanner

<div class="onboard">
    <div class="card">
        <img src="logo-text.png" alt="Mesh" class="onboard-logo" />
        <p class="sub">Mesh is your encrypted personal AI - give it a handle so other agents can reach it, and you control exactly who can.</p>

        @if (step == 0)
        {
            @if (State.HasSavedAccounts)
            {
                <div class="account-picker">
                    <div class="picker-label">Switch to a saved identity</div>
                    @foreach (var a in State.Accounts)
                    {
                        <button class="account-pick" disabled="@Working" @onclick="() => SwitchTo(a)">
                            <i class="bi bi-person-circle"></i>
                            <span class="pick-text">
                                <b>@("@")@a.Handle</b>
                                @if (!string.IsNullOrWhiteSpace(a.DisplayName) && a.DisplayName != a.Handle)
                                {
                                    <small>@a.DisplayName</small>
                                }
                            </span>
                            <i class="bi bi-box-arrow-in-right"></i>
                        </button>
                    }
                    <div class="picker-or">or add another</div>
                </div>
            }
            <div class="onboard-choice">
                <button class="choice-card" @onclick="ChooseNew">
                    <i class="bi bi-person-plus"></i>
                    <span class="ch-title">Create a new identity</span>
                    <span class="ch-sub">Pick a fresh handle for your agent.</span>
                </button>
                <button class="choice-card" @onclick="ChooseLink">
                    <i class="bi bi-qr-code-scan"></i>
                    <span class="ch-title">Link an existing device</span>
                    <span class="ch-sub">Already have Mesh elsewhere? Join the same handle with a code.</span>
                </button>
                <button class="choice-card" @onclick="ChooseRestore">
                    <i class="bi bi-box-arrow-in-down"></i>
                    <span class="ch-title">Restore from a backup</span>
                    <span class="ch-sub">Moving to this device? Bring your identity from an encrypted backup file.</span>
                </button>
            </div>
            @if (error is not null) { <p class="err">@error</p> }
        }
        else if (step == 1)
        {
            <label>Pick your handle</label>
            <div class="handle-row">
                <span>@@</span>
                <input @bind="handle" @bind:event="oninput" placeholder="yourname" />
            </div>
            <label>Display name (optional)</label>
            <input class="full" @bind="displayName" placeholder="Your Name" />
            <button class="primary" disabled="@(!ValidHandle)" @onclick="NextFromHandle">Continue</button>
            <button class="ghost" @onclick="() => step = 0">Back</button>
            <p class="hint">A device identity key is generated locally and never leaves this device.</p>
        }
        else if (step == 3) // link an existing device
        {
            @if (QrScanner.IsSupported)
            {
                <button class="primary full" disabled="@Working" @onclick="ScanQr">
                    <i class="bi bi-qr-code-scan"></i> Scan QR code
                </button>
                <div class="picker-or">or enter the details manually</div>
            }
            <label>Relay URL</label>
            <input class="full" @bind="relayUrl" placeholder="https://mesh-relay...azurecontainerapps.io" />
            <label>Handle to join</label>
            <div class="handle-row">
                <span>@@</span>
                <input @bind="handle" @bind:event="oninput" placeholder="yourname" />
            </div>
            <label>Link code <span class="muted">(from your other device → Settings → Link a device)</span></label>
            <input class="full" @bind="linkCode" placeholder="paste code" />
            <button class="primary" disabled="@(Working || !ValidLink)" @onclick="RedeemLink">
                @(Working ? "Linking..." : "Link this device")
            </button>
            <button class="ghost" @onclick="() => step = 0">Back</button>
            @if (error is not null) { <p class="err">@error</p> }
            <p class="hint">This device gets its own key, authorized under @("@")@handle. Nothing is copied off your other device.</p>
        }
        else if (step == 4) // restore from an encrypted backup
        {
            @if (!restoreImported)
            {
                <label>Relay URL</label>
                <input class="full" @bind="relayUrl" placeholder="https://mesh-relay...azurecontainerapps.io" />
                <label>Backup passphrase</label>
                <input class="full" type="password" @bind="passphrase" placeholder="the passphrase you set when you made the backup" />
                <button class="primary" disabled="@(Working || !ValidRestore)" @onclick="PickAndImport">
                    @(Working ? "Restoring..." : "Choose backup file and restore")
                </button>
                <button class="ghost" @onclick="() => step = 0">Back</button>
                @if (error is not null) { <p class="err">@error</p> }
                <p class="hint">Your backup carries all your data plus the handle recovery key, but not device keys. This device gets its own fresh key.</p>
            }
            else
            {
                <p class="sub">Restored <b>@("@")@State.Profile.Handle</b>. Now authorize this device to talk under that handle.</p>
                <button class="primary full" disabled="@Working" @onclick="RecoverThisDevice">
                    @(Working ? "Recovering..." : "This is a new device, my old device is gone")
                </button>
                <p class="hint">Uses the recovery key from your backup to re-authorize this device. Pick this when the old device is no longer available.</p>
                <button class="ghost full" disabled="@Working" @onclick="LinkAfterImport">My old device still works, I'll link with a code</button>
                <p class="hint">Generate a link code on the old device (Settings, Link a device) and join from there instead.</p>
                @if (error is not null) { <p class="err">@error</p> }
            }
        }
        else if (step == 2)
        {
            <label>Connect a model</label>
            <button class="primary full" disabled="@Working" @onclick="StartFree">@(Working && provider == "MeshHosted" ? "Setting up..." : "Start free")</button>
            <p class="hint">Runs on a shared Mesh model, no API key needed. You can switch to your own model anytime in Settings.</p>
            @if (!PlatformCaps.IsMobile)
            {
                <p class="hint">Prefer to stay fully on your machine? Foundry Local runs a free model on-device (pick it under "Use my own model" below).</p>
            }

            <button class="ghost" @onclick="() => showAdvanced = !showAdvanced">@(showAdvanced ? "Hide advanced options" : "Use my own model key")</button>

            @if (showAdvanced)
            {
                <div class="advanced">
                    <label>Connect a model <span class="muted">(runs with your key, on your device)</span></label>
                    <select class="full" @bind="provider">
                        <option value="Anthropic">Anthropic (Claude)</option>
                        <option value="OpenAI">OpenAI</option>
                        <option value="Gemini">Google Gemini</option>
                        <option value="Grok">Grok (xAI)</option>
                        <option value="Groq">Groq (fast inference)</option>
                        <option value="AzureOpenAI">Azure OpenAI</option>
                        @if (!PlatformCaps.IsMobile)
                        {
                            <option value="FoundryLocal">Foundry Local (free, on-device, desktop)</option>
                        }
                    </select>

                    @if (provider == "FoundryLocal")
                    {
                        <p class="hint" style="margin-top:12px;">Runs locally, no key, no cost. Mesh starts Foundry Local and picks up your installed model automatically. Make sure Foundry Local is installed with a model pulled.</p>
                    }
                    else
                    {
                        <label>@(provider == "AzureOpenAI" ? "Deployment name" : "Model")</label>
                        <input class="full" @bind="model" placeholder="@ModelPlaceholder" />

                        @if (provider == "OpenAI")
                        {
                            <label>Endpoint <span class="muted">(optional)</span></label>
                            <input class="full" @bind="endpoint" placeholder="https://api.openai.com" />
                        }
                        @if (provider == "AzureOpenAI")
                        {
                            <label>Endpoint</label>
                            <input class="full" @bind="endpoint" placeholder="https://your-resource.openai.azure.com" />
                            <label>API version <span class="muted">(optional)</span></label>
                            <input class="full" @bind="apiVersion" placeholder="2024-08-01-preview" />
                        }

                        <label>API key</label>
                        <input class="full" type="password" @bind="apiKey" placeholder="paste key" />
                    }

                    <button class="primary" disabled="@Working" @onclick="Finish">@(Working && provider != "MeshHosted" ? "Setting up..." : "Start using Mesh")</button>
                </div>
            }

            <button class="ghost" @onclick="BackFromModel">Back</button>
            @if (error is not null) { <p class="err">@error</p> }
        }
    </div>
</div>

@code {
    [Parameter] public EventCallback OnDone { get; set; }

    int step = 0;
    bool linkMode;
    string handle = "";
    string displayName = "";
    string relayUrl = "";
    string linkCode = "";
    string passphrase = "";
    bool restoreImported;
    string provider = "Anthropic";
    string model = "claude-3-5-sonnet-20241022";
    string endpoint = "";
    string apiKey = "";
    string apiVersion = "";
    bool Working;
    bool showAdvanced;
    string? error;

    protected override void OnInitialized()
        => relayUrl = string.IsNullOrWhiteSpace(State.Profile.RelayUrl) ? "" : State.Profile.RelayUrl;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        var pending = State.PendingPairingLink;
        if (pending is null)
            return;

        State.ConsumePendingPairingLink();
        ApplyPairing(pending.Value);
        await InvokeAsync(StateHasChanged);
        if (ValidLink)
            await RedeemLink();
    }

    bool ValidHandle => handle.Trim().Length >= 2 && handle.Trim().All(c => char.IsLetterOrDigit(c) || c is '_' or '-');
    bool ValidLink => ValidHandle && ValidRelay(relayUrl) && linkCode.Trim().Length is >= 6 and <= 512;
    bool ValidRestore => !string.IsNullOrWhiteSpace(relayUrl) && !string.IsNullOrWhiteSpace(passphrase);

    string ModelPlaceholder => provider switch
    {
        "Anthropic" => "claude-sonnet-4-6",
        "Gemini" => "gemini-1.5-flash",
        "Grok" => "grok-2-latest",
        "Groq" => "llama-3.3-70b-versatile",
        "AzureOpenAI" => "my-gpt-4o-mini (deployment name)",
        _ => "gpt-4o-mini"
    };

    void ChooseNew() { linkMode = false; step = 1; }
    void ChooseLink() { linkMode = true; step = 3; }
    void ChooseRestore() { linkMode = false; restoreImported = false; error = null; step = 4; }

    async Task ScanQr()
    {
        error = null;
        try
        {
            var raw = await QrScanner.ScanAsync();
            if (raw is null) return;
            if (!DeepLink.TryParsePairing(raw, out var pairing))
            {
                error = "That QR code is not a valid Mesh device-link.";
                return;
            }
            ApplyPairing(pairing);
            if (!ValidLink)
            {
                error = "The QR code is missing a valid handle, link code, or HTTPS relay URL.";
                return;
            }
            await RedeemLink();
        }
        catch (OperationCanceledException) { }
        catch (Exception ex) { error = ex.Message; }
    }

    async Task PickAndImport()
    {
        error = null;
        Working = true;
        try
        {
            var res = await Microsoft.Maui.Storage.FilePicker.Default.PickAsync();
            if (res is null) { Working = false; return; }
            byte[] bytes;
            using (var stream = await res.OpenReadAsync())
            using (var ms = new MemoryStream())
            {
                await stream.CopyToAsync(ms);
                bytes = ms.ToArray();
            }

            MeshProfile profile;
            try
            {
                profile = MeshExport.Open(bytes, passphrase);
            }
            catch (System.Security.Cryptography.CryptographicException)
            {
                error = "Wrong passphrase or corrupt backup.";
                return;
            }
            catch (FormatException)
            {
                error = "That file is not a Mesh backup.";
                return;
            }

            profile.RelayUrl = relayUrl.Trim();
            State.ImportProfile(profile);
            handle = State.Profile.Handle;
            restoreImported = true;
        }
        catch (Exception ex) { error = ex.Message; }
        finally { Working = false; }
    }

    async Task RecoverThisDevice()
    {
        error = null;
        Working = true;
        try
        {
            var (ok, err) = await Mesh.RecoverHandleAsync();
            if (!ok) { error = err ?? "Recovery failed."; return; }
            await Mesh.RegisterAsync();
            await Mesh.ConnectAsync();
            await OnDone.InvokeAsync();
        }
        catch (Exception ex) { error = ex.Message; }
        finally { Working = false; }
    }

    void LinkAfterImport()
    {
        // The handle is already imported; reuse the existing link step to authorize this device.
        linkMode = true;
        error = null;
        step = 3;
    }

    async Task SwitchTo(AccountRef a)
    {
        error = null;
        Working = true;
        try
        {
            await Mesh.DisconnectAsync();
            if (State.SwitchAccount(a.Id))
            {
                await Mesh.RegisterAsync();
                await Mesh.ConnectAsync();
                await OnDone.InvokeAsync();
            }
            else { error = "That identity could not be loaded."; }
        }
        catch (Exception ex) { error = ex.Message; }
        finally { Working = false; }
    }

    void NextFromHandle()
    {
        model = ModelPlaceholder;
        step = 2;
    }

    void BackFromModel() => step = linkMode ? 3 : 1;

    async Task StartFree()
    {
        provider = "MeshHosted";
        model = State.Profile.HostedModelName;
        apiKey = "";
        endpoint = "";
        await Finish();
    }

    async Task RedeemLink()
    {
        error = null;
        Working = true;
        try
        {
            TryParseLinkUri();
            if (!ValidHandle)
            {
                error = "Enter a valid handle using letters, numbers, hyphens, or underscores.";
                return;
            }
            if (!ValidRelay(relayUrl))
            {
                error = "Enter a valid HTTPS relay URL. HTTP is allowed only for local development.";
                return;
            }
            if (linkCode.Trim().Length is < 6 or > 512)
            {
                error = "Enter a valid link code.";
                return;
            }
            // This device needs its own keypair before it can prove key possession to the relay.
            if (string.IsNullOrWhiteSpace(State.Profile.PrivateKey))
            {
                var (priv, pub) = IdentityService.GenerateKeyPair();
                State.Mutate(p => { p.PrivateKey = priv; p.PublicKey = pub; });
            }
            var (ok, err) = await Mesh.RedeemLinkAsync(relayUrl.Trim(), handle.Trim(), linkCode.Trim());
            if (!ok) { error = err ?? "Linking failed."; return; }
            model = ModelPlaceholder;
            step = 2; // now configure a model on this device
        }
        catch (Exception ex) { error = ex.Message; }
        finally { Working = false; }
    }

    void TryParseLinkUri()
    {
        var candidate = linkCode.Trim();
        if (DeepLink.TryParsePairing(candidate, out var pairing))
            ApplyPairing(pairing);
    }

    void ApplyPairing(DeepLink.Parsed pairing)
    {
        linkMode = true;
        step = 3;
        handle = pairing.Handle ?? "";
        linkCode = pairing.PairingCode ?? "";
        if (!string.IsNullOrWhiteSpace(pairing.RelayUrl))
            relayUrl = pairing.RelayUrl;
    }

    static bool ValidRelay(string value)
    {
        if (!Uri.TryCreate(value.Trim(), UriKind.Absolute, out var uri))
            return false;
        if (!string.IsNullOrEmpty(uri.UserInfo) || !string.IsNullOrEmpty(uri.Query) ||
            !string.IsNullOrEmpty(uri.Fragment))
            return false;
        if (uri.Scheme == Uri.UriSchemeHttps)
            return true;
        return uri.Scheme == Uri.UriSchemeHttp
            && (uri.IsLoopback || uri.Host.Equals("10.0.2.2", StringComparison.OrdinalIgnoreCase));
    }

    async Task Finish()
    {
        error = null;
        Working = true;
        try
        {
            var mdl = string.IsNullOrWhiteSpace(model) ? ModelPlaceholder : model.Trim();

            if (!linkMode)
            {
                var h = AppState.Norm(handle);

                // Guard 1: don't allow two local identities with the same handle on this device.
                if (State.HasLocalHandle(h))
                {
                    error = $"You already have an identity for @{h} on this device.";
                    return;
                }

                // Guard 2: the handle must be free on the relay. Check BEFORE creating any local
                // identity so a taken name can never produce a stranded, unusable account.
                var taken = await Mesh.IsHandleTakenAsync(h);
                if (taken == true) { error = $"@{h} is already taken. Please choose a different handle."; return; }
                if (taken is null) { error = "Couldn't reach the relay to check that handle. Check your connection and try again."; return; }
            }

            State.Mutate(p =>
            {
                if (!linkMode)
                {
                    var (priv, pub) = IdentityService.GenerateKeyPair();
                    p.Handle = AppState.Norm(handle);
                    p.DisplayName = string.IsNullOrWhiteSpace(displayName) ? handle.Trim() : displayName.Trim();
                    p.PrivateKey = priv;
                    p.PublicKey = pub;
                }
                p.Model = new ModelConfig
                {
                    Provider = Enum.Parse<ModelProvider>(provider),
                    Model = mdl,
                    ApiKey = apiKey.Trim(),
                    Endpoint = string.IsNullOrWhiteSpace(endpoint) ? null : endpoint.Trim(),
                    ApiVersion = string.IsNullOrWhiteSpace(apiVersion) ? null : apiVersion.Trim()
                };
            });

            if (!linkMode)
            {
                // Register the fresh handle. If the relay rejects it (for example someone claimed the
                // name in the moment between the check and now), roll the local identity back so we
                // never leave a stranded account behind.
                var ok = await Mesh.RegisterAsync();
                if (!ok)
                {
                    var strandedId = State.ActiveAccountId;
                    if (strandedId is not null) State.DeleteAccount(strandedId);
                    error = $"@{AppState.Norm(handle)} could not be registered (it may have just been taken). Please try another handle.";
                    return;
                }
            }
            await Mesh.ConnectAsync();
            await OnDone.InvokeAsync();
        }
        catch (Exception ex) { error = ex.Message; }
        finally { Working = false; }
    }
}
