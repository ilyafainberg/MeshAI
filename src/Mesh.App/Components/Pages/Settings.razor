    void OnProviderChange(ChangeEventArgs e)
    {
        provider = e.Value?.ToString() ?? "Anthropic";
        if (provider == "MeshHosted")
        {
            model = ""; // the free model's id is chosen server-side
        }
        else if (provider == "Browser")
        {
            model = "browser";
        }
        else if (provider == "OpenRouter")
        {
            model = "openrouter/auto"; // OpenRouter routes by the user's account settings; client never pins a model
        }
        else if (provider == "GitHubCopilot")
        {
            model = "auto";
            copilotExecutable = string.IsNullOrWhiteSpace(copilotExecutable) ? "copilot" : copilotExecutable;
            copilotEffort = "Auto";
            copilotModelIsCustom = false;
            _ = LoadCopilotModelsAsync();
        }
        else if (provider == "FoundryLocal")
        {
            foundryModels = Foundry.CachedModels.ToList();
            // Only pick a default when the current selection isn't an on-device model.
            if (!IsFoundryId(model))
                model = foundryModels.FirstOrDefault(m => m.Id == FoundryLocalService.DefaultModel)?.Id
                        ?? foundryModels.FirstOrDefault()?.Id
                        ?? FoundryLocalService.DefaultModel;
        }
        else if (IsFoundryId(model) || string.Equals(model, "auto", StringComparison.OrdinalIgnoreCase))
        {
            model = ""; // let the provider's placeholder show
        }

        // For providers with a curated catalog, default to the top model when the current id is not
        // in the new provider's list, so the dropdown never lands on a stale/foreign model id.
        if (ModelCatalog.HasCatalog(Enum.Parse<ModelProvider>(provider)))
        {
            var opts = CatalogOptions;
            if (!opts.Any(o => o.Id == model)) model = opts[0].Id;
        }
        SyncModelCustomFlag();
    }

    string CopilotModelSelectValue
        => !copilotModelIsCustom && copilotModels.Any(option => option.Id.Equals(model, StringComparison.OrdinalIgnoreCase))
            ? copilotModels.First(option => option.Id.Equals(model, StringComparison.OrdinalIgnoreCase)).Id
            : string.Equals(model, "auto", StringComparison.OrdinalIgnoreCase) || string.IsNullOrWhiteSpace(model)
                ? "auto"
                : "__custom__";

    static string CopilotModelLabel(CopilotModelOption option)
    {
        var suffix = string.IsNullOrWhiteSpace(option.Usage) ? "" : $" ({option.Usage})";
        return option.Name + suffix + (option.Enabled ? "" : " - unavailable");
