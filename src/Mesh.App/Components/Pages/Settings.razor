            await Mesh.DisconnectAsync();
            State.SignOut(); // keeps the identity saved; returns app to the picker
        }
        finally { signingOut = false; }
    }

    async Task Switch(AccountRef a)
    {
        if (a.Id == State.ActiveAccountId || switching) return;
        switching = true;
        try
        {
            await Mesh.DisconnectAsync();
            if (State.SwitchAccount(a.Id))
            {
                SyncFields();
                await Mesh.RegisterAsync();
                await Mesh.ConnectAsync();
            }
        }
        finally { switching = false; }
    }

    // Copies a public, shareable web link to this handle to the clipboard (works for anyone: the
    // meshrelay.net landing page bounces to the mesh:// deep link or offers install).
    string? copiedHandle;
    async Task ShareHandle(AccountRef a)
    {
        try
        {
            await Microsoft.Maui.ApplicationModel.DataTransfer.Clipboard.Default.SetTextAsync(UniversalLink.ForHandle(a.Handle));
            copiedHandle = a.Handle;
            StateHasChanged();
            await Task.Delay(2000);
            if (copiedHandle == a.Handle) { copiedHandle = null; StateHasChanged(); }
        }
        catch { /* clipboard is best-effort */ }
    }

    async Task DeleteAccount(AccountRef a)
    {
        deleteId = null;
        var wasActive = a.Id == State.ActiveAccountId;

        // Release the handle on the relay first, so the name is freed and can be re-created. Signed
        // with this identity's own key: the relay only honors it if this device's key is the one
        // registered under the handle (a stranded duplicate simply won't be authorized, which is
        // correct, it never owned the name). Best-effort: a relay error still deletes locally.
        var keys = State.PeekIdentityKeys(a.Id);
        if (keys is { } k && !string.IsNullOrWhiteSpace(k.handle))
            await Mesh.DeleteHandleAsync(k.handle, k.privateKey, k.publicKey);

        if (wasActive) await Mesh.DisconnectAsync();
        State.DeleteAccount(a.Id);
        if (wasActive) SyncFields(); // active cleared → app shows the picker
    }

    // On mobile, Foundry Local (On Device) cannot run, so a persisted FoundryLocal profile is coerced
    // to the safe hosted default for the UI. Saving keeps that coerced value.
    string EffectiveProvider(ModelProvider pv)
        => PlatformCaps.IsMobile && pv is ModelProvider.FoundryLocal or ModelProvider.GitHubCopilot
