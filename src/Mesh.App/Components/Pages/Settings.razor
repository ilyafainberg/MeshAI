    static bool IsFoundryId(string id) =>
        id.Contains("generic-cpu", StringComparison.OrdinalIgnoreCase) || id.Contains("-instruct-", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        State.Changed += Refresh;
        Mesh.StateChanged += Refresh;
        Setup.Changed += Refresh;
        Foundry.ModelsChanged += Refresh;
        var p = State.Profile;
        display = p.DisplayName;
        relay = p.RelayUrl;
        provider = EffectiveProvider(p.Model.Provider);
        model = p.Model.Model;
        endpoint = p.Model.Endpoint ?? "";
        apiVersion = p.Model.ApiVersion ?? "";
        reasoningEffort = p.Model.ReasoningEffort.ToString();
        copilotExecutable = string.IsNullOrWhiteSpace(p.Model.CopilotExecutable) ? "copilot" : p.Model.CopilotExecutable;
        copilotEffort = p.Model.CopilotEffort.ToString();
        browserEngine = string.IsNullOrWhiteSpace(p.Model.BrowserEngine) ? "Firefox" : p.Model.BrowserEngine;
        browserUrl = p.Model.BrowserUrl ?? "";
        browserExecuteScript = p.Model.BrowserExecuteScript ?? browserExecuteScript;
        browserPollScript = p.Model.BrowserPollScript ?? browserPollScript;
        browserResultScript = p.Model.BrowserResultScript ?? browserResultScript;
        browserPollSeconds = p.Model.BrowserPollSeconds;
        browserTimeoutMinutes = p.Model.BrowserTimeoutMinutes;
        approvalMode = p.ApprovalMode.ToString();
        allowApps = p.AllowInteractiveApps;
        replyBudget = p.AgentDailyReplyBudget;
        // Use the list cached at app startup, do NOT reload here (that would reset the selection).
        foundryModels = Foundry.CachedModels.ToList();
        SyncModelCustomFlag();

        // Adopt any update already discovered by the background auto-check so the panel shows it
        // immediately (for example when the user arrives here via the update banner).
        if (Updater.Available is not null)
        {
            updateAvailable = true;
            updateInfo = Updater.Available;
        }
        Updater.Changed += Refresh;

        launchAtStartup = AppControl.IsLaunchAtStartupEnabled();
    }

    List<Mesh.Shared.DeviceInfo> devices = new();
    IReadOnlyList<Mesh.Shared.DeviceInfo> EligibleHomeDevices => devices
        .Where(d => d.IsEligibleHomeAgent && d.DeviceId != Mesh.MyDeviceId)
        .OrderByDescending(d => d.Online)
        .ThenBy(d => d.Name)
        .ToList();
    bool HasValidHomeDevice => EligibleHomeDevices.Any(d => d.DeviceId == State.Profile.HomeDeviceId && d.Online);
    bool HasStaleHomeDevice => !string.IsNullOrWhiteSpace(State.Profile.HomeDeviceId) && !HasValidHomeDevice;
    bool loadingDevices;
    string? deviceDirectoryError;
    string? registrationError;

