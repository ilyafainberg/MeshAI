    void Refresh()
    {
        // Keep the dropdown in sync if the startup preload finishes while Settings is open.
        if (foundryModels.Count == 0 && Foundry.CachedModels.Count > 0)
            foundryModels = Foundry.CachedModels.ToList();
        InvokeAsync(StateHasChanged);
