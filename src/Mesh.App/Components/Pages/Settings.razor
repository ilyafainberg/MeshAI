@page "/settings"
@inject AppState State
@inject MeshClient Mesh
@inject MsalAuthService Msal
@inject FoundryLocalService Foundry
@inject CopilotAcpHost Copilot
@inject ModelSetupService Setup
@inject IHttpClientFactory HttpFactory
@inject UpdateService Updater
@inject IAppControl AppControl
@implements IDisposable

<div class="pane-scroll">
    <div class="pane-narrow">
        <div class="pane-head" style="padding-left:0;padding-right:0;">
            <h2><i class="bi bi-gear"></i> Settings</h2>
        </div>

        <div class="card-panel">
            <h3>Identity</h3>
            <div class="field-row">
                <div><div class="field-label">Handle</div><div class="field-sub">how others add you</div></div>
                <b>@State.Profile.Handle</b>
            </div>
            <div class="field">
                <label>Display name</label>
                <input class="full" value="@display" @onchange="OnDisplayChanged" />
                <div class="field-hint">Shown to your contacts instead of your handle. Saved automatically.</div>
            </div>
            <h3>Link a device</h3>
            <div class="field-hint" style="margin-bottom:12px;">
                Add your phone or another computer to the same handle. On the other device, choose
                <b>Link an existing device</b> and enter this code. Single-use, expires in 5&nbsp;minutes.
            </div>
            @if (linkCode is null)
            {
                <button class="ghost" disabled="@linkWorking" @onclick="CreateInvite">
                    @(linkWorking ? "Generating..." : "Generate link code")
                </button>
                @if (linkError is not null) { <p class="err">@linkError</p> }
            }
            else
            {
                <div class="link-invite">
                    @if (qrDataUri is not null)
                    {
                        <img class="link-qr" src="@qrDataUri" alt="Link QR code" />
                    }
                    <div class="link-code-box">
                        <code class="link-code">@linkCode</code>
                        <div class="field-sub">Expires in @remaining s</div>
                    </div>
                </div>
                <button class="ghost" @onclick="ClearInvite">Done</button>
            }
            <h3>Identities on this device</h3>
            <div class="field-hint" style="margin-bottom:12px;">
                Keep several handles on this device and switch between them without signing out of any.
            </div>
            <div class="account-list">
                @foreach (var a in State.Accounts)
                {
                    var isActive = a.Id == State.ActiveAccountId;
                    <div class="account-row @(isActive ? "active" : "")">
                        <div class="account-info">
                            <i class="bi bi-person-circle"></i>
                            <div class="account-text">
                                <b>@("@")@a.Handle</b>
                                @if (!string.IsNullOrWhiteSpace(a.DisplayName) && a.DisplayName != a.Handle)
                                {
                                    <small class="muted">@a.DisplayName</small>
                                }
                            </div>
                        </div>
                        <div class="account-actions">
                            @if (isActive)
                            {
                                <span class="vis shared">current</span>
                            }
                            else
                            {
                                <button class="ghost" disabled="@switching" @onclick="() => Switch(a)">Switch</button>
                            }
                            <button class="icon-btn" title="Copy a shareable link to this handle" aria-label="Copy share link" @onclick="() => ShareHandle(a)"><i class="bi bi-share"></i></button>
                            @if (copiedHandle == a.Handle)
                            {
                                <span class="vis shared" title="Link copied to clipboard">copied</span>
                            }
                            @if (deleteId == a.Id)
                            {
                                <button class="danger" @onclick="() => DeleteAccount(a)">Delete</button>
                                <button class="ghost icon-btn" @onclick="() => deleteId = null" title="Cancel" aria-label="Cancel"><i class="bi bi-x-lg"></i></button>
                            }
                            else
                            {
                                <button class="icon-btn" title="Remove from this device" @onclick="() => deleteId = a.Id" aria-label="Remove from this device"><i class="bi bi-trash"></i></button>
                            }
                        </div>
                    </div>
                }
            </div>
            <h3>Sign out</h3>
            <div class="field-hint" style="margin-bottom:12px;">
                Sign out of <b>@("@")@State.Profile.Handle</b> and return to the account picker. Your identity
                stays saved on this device, you can switch back anytime, or add / link another handle.
                Nothing is deleted.
            </div>
            @if (!confirmSignOut)
            {
                <button class="ghost" @onclick="() => confirmSignOut = true">
                    <i class="bi bi-box-arrow-right"></i> Sign out / switch identity
                </button>
            }
            else
            {
                <div class="confirm-row">
                    <span class="muted">Sign out of @("@")@State.Profile.Handle? It stays saved on this device.</span>
                    <button class="primary" disabled="@signingOut" @onclick="SignOut">
                        @(signingOut ? "Signing out…" : "Sign out")
                    </button>
                    <button class="ghost" disabled="@signingOut" @onclick="() => confirmSignOut = false">Cancel</button>
                </div>
            }
        </div>

        <div class="card-panel">
            <h3>Model</h3>
            <div class="field">
                <label>Provider</label>
                <select class="full" value="@provider" @onchange="OnProviderChange">
                    <option value="MeshHosted">Mesh free model (no key)</option>
                    <option value="Anthropic">Anthropic (Claude)</option>
                    <option value="OpenAI">OpenAI</option>
                    <option value="Gemini">Google Gemini</option>
                    <option value="Grok">Grok (xAI)</option>
                    <option value="Groq">Groq (fast inference)</option>
                    <option value="OpenRouter">OpenRouter</option>
                    <option value="AzureOpenAI">Azure OpenAI</option>
                    @if (!PlatformCaps.IsMobile)
                    {
                        <option value="FoundryLocal">On Device</option>
                        @if (OperatingSystem.IsWindows())
                        {
                            <option value="Browser">Browser model (scripted)</option>
                        }
                        <option value="GitHubCopilot">GitHub Copilot CLI (ACP)</option>
                    }
                </select>
            </div>

            @if (provider == "MeshHosted")
            {
                <div class="field">
                    <div class="connector-note">
                        <i class="bi bi-gift"></i>
                        <span>The Mesh free model runs on a shared Mesh-hosted model, no API key needed. There is a daily token budget, so it can pause once that budget is used up for the day. Switch to your own key@(PlatformCaps.IsMobile ? "" : " or an on-device model") for unlimited use.</span>
                    </div>
                </div>
            }
            else if (provider == "GitHubCopilot")
            {
                <div class="field">
                    <div class="connector-note">
                        <i class="bi bi-github"></i>
                        <span>Desktop only. Uses your installed and signed-in GitHub Copilot CLI through ACP. Mesh does not store a GitHub token. Copilot native tools stay disabled; enabled Mesh tools remain available with their Mesh approval settings.</span>
                    </div>
                </div>
                <div class="field">
                    <label>Copilot command</label>
                    <input class="full" @bind="copilotExecutable" placeholder="copilot" autocomplete="off" />
                    <div class="field-hint">Use <code>copilot</code> when it is on PATH, or enter the full path to the executable or command file. Run <code>copilot login</code> in a terminal first.</div>
                </div>
                <div class="field">
                    <label>Model</label>
                    <div class="model-row">
                        <select class="full" value="@CopilotModelSelectValue" @onchange="OnCopilotModelSelect">
                            @if (copilotModels.Count == 0)
                            {
                                <option value="auto">Automatic (Copilot chooses)</option>
                            }
                            @foreach (var option in copilotModels)
                            {
                                <option value="@option.Id" disabled="@(!option.Enabled)">@CopilotModelLabel(option)</option>
                            }
                            <option value="__custom__">Custom model ID...</option>
                        </select>
                        <button class="ghost icon-btn" title="Refresh Copilot model list"
                                @onclick="() => LoadCopilotModelsAsync(force: true)"
                                disabled="@loadingCopilotModels"
                                aria-label="Refresh Copilot model list">
                            <i class="bi @(loadingCopilotModels ? "bi-hourglass-split" : "bi-arrow-repeat")"></i>
                        </button>
                    </div>
                    @if (copilotModelIsCustom)
                    {
                        <input class="full" style="margin-top:8px;" @bind="model" placeholder="Model ID, for example gpt-5.4" />
                    }
                    <div class="field-hint">The list comes from the installed CLI and reflects models enabled for your Copilot account. Automatic lets Copilot choose.</div>
                    @if (!string.IsNullOrWhiteSpace(copilotModelsError))
                    {
                        <div class="err-text" role="alert">@copilotModelsError</div>
                    }
                </div>
                <div class="field">
                    <label>Reasoning effort</label>
                    <select class="full" @bind="copilotEffort">
                        <option value="Auto">Auto (Copilot default)</option>
                        <option value="None">None</option>
                        <option value="Minimal">Minimal</option>
                        <option value="Low">Low</option>
                        <option value="Medium">Medium</option>
                        <option value="High">High</option>
                        <option value="XHigh">Extra high</option>
                        <option value="Max">Maximum</option>
                    </select>
                    <div class="field-hint">Changing the model or effort restarts the local ACP process for the next response.</div>
                </div>
            }
            else if (provider == "FoundryLocal")
            {
                    <div class="field">
                        <label>Model</label>
                        <div class="model-row">
                            <select class="full" @bind="model">
                                @if (!string.IsNullOrWhiteSpace(model) && !foundryModels.Any(m => m.Id == model))
                                {
                                    <option value="@model">@model (current)</option>
                                }
                                @foreach (var m in foundryModels)
                                {
                                    <option value="@m.Id">@m.Label</option>
                                }
                            </select>
                            <button class="ghost icon-btn" title="Refresh model list" @onclick="RefreshModels" disabled="@loadingModels" aria-label="Refresh model list">
                                <i class="bi @(loadingModels ? "bi-hourglass-split" : "bi-arrow-repeat")"></i>
                            </button>
                        </div>
                    <div class="field-hint">
                        Runs on this device, no key, no cost. Only tool-capable models are listed.
                        Your pick is downloaded and started automatically when you Save (first time can take a while).
                    </div>
                    <div class="field-hint star-note">
                        <span class="stars">★★★★★</span> = most capable. More stars mean a bigger, smarter model that needs better hardware (more RAM/CPU); fewer stars run faster on modest machines.
                    </div>
                    @if (loadingModels)
                    {
                        <div class="field-hint"><i class="bi bi-hourglass-split"></i> Finding on-device models…</div>
                    }
                    else if (foundryModels.Count == 0)
                    {
                        <div class="connector-note">
                            <i class="bi bi-cpu"></i>
                            <span>Couldn't list on-device models yet. Foundry Local will be installed and started when you Save; smaller models load fastest.</span>
                        </div>
                    }
                </div>
            }
            else if (provider == "Browser")
            {
                <div class="field">
                    <div class="connector-note">
                        <i class="bi bi-window"></i>
                        <span>Windows only. Mesh opens a dedicated persistent browser on first use in every Mesh session. Sign in, return to Mesh, and select OK. Scripts run inside the provider page and can read anything rendered there.</span>
                    </div>
                </div>
                <div class="field">
                    <label>Browser</label>
                    <select class="full" @bind="browserEngine">
                        <option value="Firefox">Firefox (recommended)</option>
                        <option value="Chrome">Chrome</option>
                        <option value="Edge">Edge</option>
                    </select>
                    <div class="field-hint">Firefox uses Playwright Firefox. Chrome and Edge use their installed Playwright channels.</div>
                </div>
                <div class="field">
                    <label>Preset file</label>
                    <InputFile OnChange="LoadBrowserPreset" accept=".json,application/json" />
                    <div class="field-hint">Load a .json browser-provider preset. Review its scripts before saving because presets contain executable JavaScript.</div>
                    @if (!string.IsNullOrWhiteSpace(browserPresetStatus))
                    {
                        <div class="field-hint">@browserPresetStatus</div>
                    }
                </div>
                <div class="field">
                    <label>Start URL</label>
                    <input class="full" @bind="browserUrl" placeholder="https://example.com/chat" />
                </div>
                <div class="field">
                    <label>Context sent to website</label>
                    <select class="full" @bind="browserContextMode">
                        <option value="CurrentTurn">Current user message only</option>
                        <option value="FullPrompt">Full Mesh prompt and history</option>
                    </select>
                    <div class="field-hint">Current turn keeps context separately in Mesh and in the website conversation. Use one website conversation per Mesh thread to avoid mixing contexts.</div>
                </div>
                <div class="field">
                    <label>Execute prompt</label>
                    <textarea class="full" rows="7" @bind="browserExecuteScript" spellcheck="false"></textarea>
                    <div class="field-hint">Async JavaScript function accepting request: prompt, systemPrompt, messages, skills, tools, metadata.</div>
                </div>
                <div class="field">
                    <label>Poll for response</label>
                    <textarea class="full" rows="6" @bind="browserPollScript" spellcheck="false"></textarea>
                    <div class="field-hint">Runs every 5 seconds by default. Return true/false or status: pending, complete, authentication-required, error.</div>
                </div>
                <div class="field">
                    <label>Get result</label>
                    <textarea class="full" rows="6" @bind="browserResultScript" spellcheck="false"></textarea>
                    <div class="field-hint">Return a string or an object such as { text: "reply" }.</div>
                </div>
                <div class="field-row">
                    <div class="field"><label>Poll seconds</label><input type="number" min="1" max="60" @bind="browserPollSeconds" /></div>
                    <div class="field"><label>Timeout minutes</label><input type="number" min="1" max="120" @bind="browserTimeoutMinutes" /></div>
                </div>
            }
            else if (provider == "OpenRouter")
            {
                <div class="field">
                    <div class="connector-note">
                        <i class="bi bi-shuffle"></i>
                        <span>OpenRouter picks the model and provider based on your OpenRouter account settings. Mesh just sends your key and lets OpenRouter route, so there is no model to choose here.</span>
                    </div>
                </div>
                <div class="field">
                    <label>API key</label>
                    <input class="full" type="password" @bind="apiKey" placeholder="(unchanged)" />
                </div>
            }
            else
            {
                @if (CatalogOptions.Count > 0)
                {
                    <div class="field">
                        <label>Model</label>
                        <select class="full" value="@ModelSelectValue" @onchange="OnModelSelect">
                            @foreach (var opt in CatalogOptions)
                            {
                                <option value="@opt.Id">@opt.Label</option>
                            }
                            <option value="__custom__">Custom...</option>
                        </select>
                        @if (modelIsCustom)
                        {
                            <input class="full" style="margin-top:8px;" @bind="model" placeholder="@ModelPlaceholder" />
                        }
                    </div>
                }
                else
                {
                    <div class="field">
                        <label>@(provider == "AzureOpenAI" ? "Deployment name" : "Model")</label>
                        <input class="full" @bind="model" placeholder="@ModelPlaceholder" />
                    </div>
                }
                @if (provider == "OpenAI")
                {
                    <div class="field">
                        <label>Endpoint <span class="muted">(optional)</span></label>
                        <input class="full" @bind="endpoint" placeholder="https://api.openai.com" />
                    </div>
                }
                @if (provider == "AzureOpenAI")
                {
                    <div class="field">
                        <label>Endpoint</label>
                        <input class="full" @bind="endpoint" placeholder="https://your-resource.openai.azure.com" />
                        <div class="field-hint">Your Azure OpenAI resource URL. The Deployment name above is your model deployment, not the base model name.</div>
                    </div>
                    <div class="field">
                        <label>API version <span class="muted">(optional)</span></label>
                        <input class="full" @bind="apiVersion" placeholder="leave blank for the current API" />
                        <div class="field-hint">Leave blank to use Azure OpenAI's current API (recommended). Only set a dated version (e.g. 2024-10-21) if your resource requires the older deployment API.</div>
                    </div>
                }
                <div class="field">
                    <label>API key</label>
                    <input class="full" type="password" @bind="apiKey" placeholder="(unchanged)" />
                </div>
            }

            @if (provider is not "MeshHosted" and not "Browser" and not "FoundryLocal" and not "GitHubCopilot")
            {
                <div class="field">
                    <label>Reasoning effort</label>
                    <select class="full" @bind="reasoningEffort">
                        <option value="Auto">Auto (model default)</option>
                        <option value="Low">Low (faster)</option>
                        <option value="Medium">Medium (balanced)</option>
                        <option value="High">High (deeper reasoning)</option>
                    </select>
                    <div class="field-hint">Controls reasoning intensity separately from the response length. The selected model must support this setting.</div>
                </div>
            }

            <div class="field" style="margin-top:8px;">
                <button class="primary" @onclick="ChangeModel" disabled="@Setup.Running">
                    <i class="bi bi-check-lg"></i> @(Setup.Running ? "Working…" : "Change model")
                </button>
                @if (Setup.Running)
                {
                    <div class="setup-status running" style="margin-top:12px;">
                        <span class="spinner"></span>
                        <span>@(Setup.Status ?? "Working…")</span>
                    </div>
                }
                else if (Setup.Success is not null)
                {
                    <div class="setup-status @(Setup.Success == true ? "ok" : "err")" style="margin-top:12px;">
                        <i class="bi @(Setup.Success == true ? "bi-check-circle" : "bi-exclamation-triangle")"></i>
                        <span>@Setup.Status</span>
                    </div>
                }
            </div>
        </div>

        <div class="card-panel">
            <h3>Usage report</h3>
            <div class="field" style="margin-top:4px;">
                <label>Token usage</label>
                <TokenMeter />
                <div class="tm-actions" style="margin-top:8px;">
                    <button class="ghost" @onclick="ResetCounter"><i class="bi bi-arrow-counterclockwise"></i> Reset counter</button>
                </div>
                <div class="field-hint">
                    Counts reset automatically when you switch models. The free hosted model has a daily
                    token budget, so it can pause once that budget is used up for the day.
                </div>
            </div>

            <div class="field-row">
                <div>
                    <div class="field-label">Estimated spend</div>
                    <div class="field-sub">Approximate cost of your usage, based on the model's published prices. Actual billing comes from your provider.</div>
                </div>
                <span>@SpendLabel</span>
            </div>
        </div>

        <div class="card-panel">
            <h3>Agent responses</h3>
            <div class="field">
                <label>Approval before replying</label>
                <select class="full" value="@approvalMode" @onchange="OnApprovalChanged">
                    <option value="Off">Auto-reply (no approval)</option>
                    <option value="PerCircle">Approve per circle (uses circle settings)</option>
                    <option value="All">Approve every reply</option>
                </select>
                <div class="field-hint">When on, your agent drafts a reply and waits for you on the Messages page before sending.</div>
            </div>
            <div class="field-row">
                <div>
                    <div class="field-label">Plan before acting</div>
                    <div class="field-sub">Generate and show a concise action plan before each standard topic turn in Me. Uses an extra model request, so responses may take longer and use more MTokens or Copilot premium requests.</div>
                </div>
                <label class="switch">
                    <input type="checkbox"
                           checked="@State.Profile.PlanBeforeActing"
                           @onchange="e => Toggle(p => p.PlanBeforeActing = (bool)(e.Value ?? false))"
                           aria-label="Plan before acting in Me topics" />
                </label>
            </div>
            <div class="field-row">
                <div>
                    <div class="field-label">Interactive apps</div>
                    <div class="field-sub">Let agents send interactive mini-apps in messages. They run sandboxed and never auto-run.</div>
                </div>
                <label class="switch"><input type="checkbox" checked="@allowApps" @onchange="OnAllowAppsChanged" aria-label="Interactive apps" /></label>
            </div>
            <div class="field-row">
                <div>
                    <div class="field-label">Do not disturb</div>
                    <div class="field-sub">Suppress all popup notifications. In-app badges still update.</div>
                </div>
                <label class="switch"><input type="checkbox" checked="@State.Profile.DoNotDisturb" @onchange="e => Toggle(p => p.DoNotDisturb = (bool)(e.Value ?? false))" aria-label="Do not disturb" /></label>
            </div>
            @if (PlatformCaps.CanHostHomeAgent)
            {
                <div class="field-row">
                    <div>
                        <div class="field-label">Answer my other devices</div>
                        <div class="field-sub">Let your linked mobile devices use this desktop's agent and full local tools.</div>
                    </div>
                    <label class="switch"><input type="checkbox" checked="@State.Profile.ActAsRemoteAgent" @onchange="OnRemoteAgentChanged" aria-label="Answer my other devices" /></label>
                </div>
                <div class="field">
                    <label>This device's name</label>
                    <input class="full" value="@State.Profile.DeviceName" @onchange="OnDeviceNameChanged" />
                    <div class="field-hint">Shown to your linked mobile devices.</div>
                </div>
                @if (registrationError is not null)
                {
                    <div class="err-text" role="alert">@registrationError</div>
                }
            }
            else if (PlatformCaps.IsMobile)
            {
                <div class="field-row">
                    <div>
                        <div class="field-label">Home device</div>
                        <div class="field-sub">Choose the desktop that answers Home Agent requests.</div>
                    </div>
                    <div class="home-device-row">
                        <select class="field" value="@(HasValidHomeDevice ? State.Profile.HomeDeviceId : "")"
                                @onchange="OnHomeDeviceChanged" aria-label="Home device">
                            <option value="">Select a desktop</option>
                            @foreach (var d in EligibleHomeDevices)
                            {
                                var label = (string.IsNullOrWhiteSpace(d.Name) ? d.DeviceId : d.Name)
                                    + (d.Online ? " - online" : " - offline");
                                <option value="@d.DeviceId" disabled="@(!d.Online)">@label</option>
                            }
                        </select>
                        <button class="ghost" @onclick="LoadDevicesAsync" disabled="@loadingDevices" aria-label="Refresh devices"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
                    </div>
                </div>
                @if (HasStaleHomeDevice)
                {
                    <div class="err-text" role="alert">Your saved Home device is no longer available. Select an online desktop.</div>
                }
                else if (deviceDirectoryError is not null)
                {
                    <div class="err-text" role="alert">@deviceDirectoryError</div>
                }
                else if (!loadingDevices && EligibleHomeDevices.Count == 0)
                {
                    <div class="field-hint muted">No eligible desktop is available. Enable Answer my other devices on a linked desktop.</div>
                }
            }
        </div>

        <div class="card-panel">
            <h3>Agent budget</h3>
            <div class="field">
                <label>Automatic replies per day</label>
                <input class="full" type="number" min="0" value="@replyBudget" @onchange="OnBudgetChanged" />
                <div class="field-hint">
                    Cap how many automatic agent replies run per day. Each reply calls your model, so this protects
                    your usage and cost. Set to 0 for unlimited.
                </div>
            </div>
            <div class="field-row">
                <div class="field-label">Used today</div>
                <span>@BudgetUsageLabel</span>
            </div>
        </div>

        <div class="card-panel">
            <h3>Relay</h3>
            <div class="field">
                <label>Relay URL</label>
                <div class="model-row">
                    <input class="full" value="@relay" @onchange="OnRelayChanged" aria-label="Relay URL" />
                    <button class="ghost" @onclick="TestRelay" disabled="@testingRelay" title="Check this relay is reachable">
                        @(testingRelay ? "Testing…" : "Test")
                    </button>
                </div>
                @if (relayTestMsg is not null) { <div class="field-hint @(relayTestOk ? "" : "err-text")">@relayTestMsg</div> }
                <div class="field-hint">
                    The default relay is run by Mesh. You can run your own, or use anyone's:
                    the relay is open source (see the About page). A handle is registered per relay,
                    so switching relays re-registers your handle there. Changes apply automatically.
                </div>
            </div>
            <div class="field-row">
                <div class="field-label">Status</div>
                <span class="@(Mesh.Connected ? "on" : "off")">
                    <i class="bi @(Mesh.Connected ? "bi-check-circle-fill" : "bi-circle")"></i>
                    @(Mesh.Connected ? "connected" : "offline")
                </span>
            </div>
        </div>

        @if (Updater.IsSupported)
        {
        <div class="card-panel">
            <h3>Updates</h3>
            <div class="field-row">
                <div class="field-label">Current version</div>
                <span>@Updater.CurrentVersion.ToString(3)</span>
            </div>

            @if (updatePhase == UpdatePhase.Downloading || updatePhase == UpdatePhase.Extracting
                 || updatePhase == UpdatePhase.Preparing || updatePhase == UpdatePhase.Applying)
            {
                <div class="field">
                    <div class="update-progress-head">
                        <span>@updateStatus</span>
                        @if (updatePercent >= 0) { <span>@updatePercent%</span> }
                    </div>
                    <div class="progress-track" role="progressbar"
                         aria-valuenow="@(updatePercent < 0 ? 0 : updatePercent)" aria-valuemin="0" aria-valuemax="100">
                        <div class="progress-fill @(updatePercent < 0 ? "indeterminate" : "")"
                             style="@(updatePercent >= 0 ? $"width:{updatePercent}%" : "")"></div>
                    </div>
                    @if (updateBytesTotal > 0)
                    {
                        <div class="field-hint">@FormatMb(updateBytesReceived) of @FormatMb(updateBytesTotal) MB</div>
                    }
                </div>
            }
            else if (updateInfo is not null && updatePhase == UpdatePhase.ReadyToApply)
            {
                <div class="field">
                    <div class="update-avail">Version @updateInfo.Version.ToString(3) is ready to install.</div>
                    <div class="field-hint">Mesh will close and the installer will open to finish updating, then reopen Mesh. Save any unsaved work first.</div>
                    <div class="model-row">
                        <button class="primary" @onclick="ApplyUpdate">Install update</button>
                        <button class="ghost" @onclick="DismissUpdate">Later</button>
                    </div>
                </div>
            }
            else if (updateInfo is not null && updateAvailable)
            {
                <div class="field">
                    <div class="update-avail">
                        <i class="bi bi-arrow-up-circle-fill"></i>
                        Version @updateInfo.Version.ToString(3) is available.
                    </div>
                    @if (!string.IsNullOrWhiteSpace(updateInfo.ReleaseNotes))
                    {
                        <details class="update-notes">
                            <summary>What's new</summary>
                            <div class="notes-md">@((MarkupString)global::Mesh.App.Services.Markdown.ToHtml(updateInfo.ReleaseNotes))</div>
                        </details>
                    }
                    <div class="model-row">
                        <button class="primary" @onclick="DownloadUpdate">
                            Download @(updateInfo.Size > 0 ? $"({FormatMb(updateInfo.Size)} MB)" : "")
                        </button>
                        @if (updateInfo.HtmlUrl is not null)
                        {
                            <button class="ghost" @onclick="() => OpenUrl(updateInfo.HtmlUrl)">View release</button>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="field">
                    <div class="model-row">
                        <button class="ghost" @onclick="CheckUpdate" disabled="@checkingUpdate">
                            @(checkingUpdate ? "Checking…" : "Check for updates")
                        </button>
                    </div>
                    @if (updateStatus is not null)
                    {
                        <div class="field-hint @(updateFailed ? "err-text" : "")">@updateStatus</div>
                    }
                </div>
            }
        </div>
        }

        @if (AppControl.IsLaunchAtStartupEnabled() || OperatingSystem.IsWindows())
        {
        <div class="card-panel">
            <h3>Application</h3>
            <div class="field-row">
                <div>
                    <div class="field-label">Launch at startup</div>
                    <div class="field-sub">Start Mesh automatically when you sign in to Windows. It opens minimized to the system tray.</div>
                </div>
                <label class="switch"><input type="checkbox" checked="@launchAtStartup" @onchange="OnToggleStartup" aria-label="Launch at startup" /></label>
            </div>
        </div>
        }

    </div>
</div>

@code {
