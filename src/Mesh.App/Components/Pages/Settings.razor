    async Task LoadCopilotModelsAsync(bool force = false)
    {
        if (loadingCopilotModels || provider != "GitHubCopilot") return;
        loadingCopilotModels = true;
        copilotModelsError = null;
        await InvokeAsync(StateHasChanged);
        try
        {
            copilotModels = (await Copilot.GetModelsAsync(
                string.IsNullOrWhiteSpace(copilotExecutable) ? "copilot" : copilotExecutable.Trim(),
                force)).ToList();
            if (!copilotModels.Any(option => option.Id.Equals("auto", StringComparison.OrdinalIgnoreCase)))
                copilotModels.Insert(0, new CopilotModelOption("auto", "Automatic", "Let Copilot choose", null, null, true));
            SyncModelCustomFlag();
        }
        catch (Exception ex)
        {
            copilotModelsError = ex.Message;
            copilotModels = new() { new CopilotModelOption("auto", "Automatic", "Let Copilot choose", null, null, true) };
            SyncModelCustomFlag();
        }
        finally
        {
            loadingCopilotModels = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    /// <summary>Manual refresh, the only place that re-queries the on-device catalog after startup.</summary>
    async Task RefreshModels()
    {
        loadingModels = true;
        await InvokeAsync(StateHasChanged);
        try { await Foundry.PreloadModelsAsync(force: true); foundryModels = Foundry.CachedModels.ToList(); }
        catch { /* leave existing list */ }
        finally { loadingModels = false; await InvokeAsync(StateHasChanged); }
    }

    async Task LoadBrowserPreset(InputFileChangeEventArgs e)
    {
        browserPresetStatus = "";
        try
        {
            await using var stream = e.File.OpenReadStream(2 * 1024 * 1024);
            using var document = await System.Text.Json.JsonDocument.ParseAsync(stream);
            var root = document.RootElement;
            if (root.ValueKind != System.Text.Json.JsonValueKind.Object)
                throw new InvalidOperationException("Preset root must be a JSON object.");

            static string? Text(System.Text.Json.JsonElement root, string name)
                => root.TryGetProperty(name, out var value) && value.ValueKind == System.Text.Json.JsonValueKind.String
                    ? value.GetString() : null;
            static int? Number(System.Text.Json.JsonElement root, string name)
                => root.TryGetProperty(name, out var value) && value.TryGetInt32(out var number) ? number : null;

            var url = Text(root, "startUrl") ?? Text(root, "url");
            var execute = Text(root, "executePrompt");
            var poll = Text(root, "pollForResponse");
            var result = Text(root, "getResult");
            if (string.IsNullOrWhiteSpace(url) || string.IsNullOrWhiteSpace(execute)
                || string.IsNullOrWhiteSpace(poll) || string.IsNullOrWhiteSpace(result))
                throw new InvalidOperationException("Preset requires startUrl, executePrompt, pollForResponse, and getResult.");

            browserUrl = url;
            browserExecuteScript = execute;
            browserPollScript = poll;
            browserResultScript = result;
            var engine = Text(root, "browser");
            if (engine is not null && new[] { "Chrome", "Edge", "Firefox" }.Contains(engine, StringComparer.OrdinalIgnoreCase))
                browserEngine = char.ToUpperInvariant(engine[0]) + engine[1..].ToLowerInvariant();
            var contextMode = Text(root, "contextMode");
            if (string.Equals(contextMode, "CurrentTurn", StringComparison.OrdinalIgnoreCase))
                browserContextMode = "CurrentTurn";
            else if (string.Equals(contextMode, "FullPrompt", StringComparison.OrdinalIgnoreCase))
                browserContextMode = "FullPrompt";
            browserPollSeconds = Math.Clamp(Number(root, "pollSeconds") ?? browserPollSeconds, 1, 60);
            browserTimeoutMinutes = Math.Clamp(Number(root, "timeoutMinutes") ?? browserTimeoutMinutes, 1, 120);
            browserPresetStatus = $"Loaded {e.File.Name}. Review the scripts, then select Change model.";
        }
        catch (Exception ex)
        {
            browserPresetStatus = "Could not load preset: " + ex.Message;
        }
    }

    async Task ChangeModel()
    {
        var apiKeyToSet = apiKey;
        apiKey = "";

        // The save + model test runs in a background singleton, so it keeps going
        // (and stays observable) even if the user navigates away from Settings. The non-model
        // fields (display name, relay, approval, budget) auto-save on change; they are set here too
        // so a single "Change model" also captures anything the user just edited.
        Setup.SaveAndTest(p =>
        {
            p.DisplayName = display.Trim();
            p.RelayUrl = relay.Trim();
            p.Model.Provider = Enum.Parse<ModelProvider>(provider);
            p.Model.Model = model.Trim();
            p.Model.Endpoint = string.IsNullOrWhiteSpace(endpoint) ? null : endpoint.Trim();
            p.Model.ApiVersion = string.IsNullOrWhiteSpace(apiVersion) ? null : apiVersion.Trim();
            p.Model.ReasoningEffort = Enum.TryParse<ReasoningEffort>(reasoningEffort, out var effort) ? effort : ReasoningEffort.Auto;
            p.Model.CopilotExecutable = string.IsNullOrWhiteSpace(copilotExecutable) ? "copilot" : copilotExecutable.Trim();
            p.Model.CopilotEffort = Enum.TryParse<CopilotEffort>(copilotEffort, out var cliEffort) ? cliEffort : CopilotEffort.Auto;
            p.Model.BrowserEngine = browserEngine;
            p.Model.BrowserContextMode = browserContextMode;
            p.Model.BrowserUrl = string.IsNullOrWhiteSpace(browserUrl) ? null : browserUrl.Trim();
            p.Model.BrowserExecuteScript = browserExecuteScript;
            p.Model.BrowserPollScript = browserPollScript;
            p.Model.BrowserResultScript = browserResultScript;
            p.Model.BrowserPollSeconds = Math.Clamp(browserPollSeconds, 1, 60);
            p.Model.BrowserTimeoutMinutes = Math.Clamp(browserTimeoutMinutes, 1, 120);
            if (!string.IsNullOrWhiteSpace(apiKeyToSet)) p.Model.ApiKey = apiKeyToSet.Trim();
            p.ApprovalMode = Enum.Parse<ApprovalMode>(approvalMode);
            p.AllowInteractiveApps = allowApps;
            p.AgentDailyReplyBudget = replyBudget < 0 ? 0 : replyBudget;
        });

        // Model may have changed; start the live counter fresh for the newly selected model.
        State.ResetTokenCounter();

        await Mesh.RegisterAsync();
    }

    // ---- auto-save for non-model settings (persist immediately on change) ----
    void OnDisplayChanged(ChangeEventArgs e)
    {
        display = e.Value?.ToString() ?? "";
        Toggle(p => p.DisplayName = display.Trim());
    }

    void OnApprovalChanged(ChangeEventArgs e)
    {
        approvalMode = e.Value?.ToString() ?? "PerCircle";
        Toggle(p => p.ApprovalMode = Enum.Parse<ApprovalMode>(approvalMode));
    }

    void OnAllowAppsChanged(ChangeEventArgs e)
    {
        allowApps = (bool)(e.Value ?? false);
        Toggle(p => p.AllowInteractiveApps = allowApps);
    }

    void OnBudgetChanged(ChangeEventArgs e)
    {
        replyBudget = int.TryParse(e.Value?.ToString(), out var v) && v > 0 ? v : 0;
        Toggle(p => p.AgentDailyReplyBudget = replyBudget);
    }

    async Task OnRelayChanged(ChangeEventArgs e)
    {
        relay = e.Value?.ToString() ?? "";
        var url = relay.Trim();
        if (string.IsNullOrWhiteSpace(url)) return;
        Toggle(p => p.RelayUrl = url);
        // A handle is registered per relay, so switching relays re-registers there and reconnects.
        try { await Mesh.RegisterAsync(); await Mesh.ConnectAsync(); } catch { }
    }

    // Estimated spend for the current model's live token counter (null when the model has no price).
    string SpendLabel
    {
        get
        {
            var t = State.Profile.Tokens;
            var cost = ModelCatalog.EstimateCost(State.Profile.Model.Model, t.PromptTokens, t.CompletionTokens);
            return cost is null ? "N/A" : $"~${cost.Value:0.00}";
        }
    }

    void ResetCounter() => State.ResetTokenCounter();

    // ---- relay test ----
    bool testingRelay;
    bool relayTestOk;
    string? relayTestMsg;

    async Task TestRelay()
    {
        relayTestMsg = null;
        var url = relay?.Trim();
        if (string.IsNullOrWhiteSpace(url)) { relayTestOk = false; relayTestMsg = "Enter a relay URL first."; return; }
        testingRelay = true;
        try
        {
            var http = HttpFactory.CreateClient("relay");
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(15));
            var resp = await http.GetAsync($"{url.TrimEnd('/')}/health", cts.Token);
            if (resp.IsSuccessStatusCode)
            {
                relayTestOk = true;
                relayTestMsg = "Relay is reachable.";
            }
            else
            {
                relayTestOk = false;
                relayTestMsg = $"Relay responded with {(int)resp.StatusCode}. Check the URL.";
            }
        }
        catch (Exception ex)
        {
            relayTestOk = false;
            relayTestMsg = $"Could not reach that relay: {ex.Message}";
        }
        finally { testingRelay = false; }
    }

    // ---- self-update ----
    bool checkingUpdate;
    bool updateAvailable;
    bool updateFailed;
    string? updateStatus;
    UpdateInfo? updateInfo;
    UpdatePhase updatePhase = UpdatePhase.Idle;
    int updatePercent = -1;
    long updateBytesReceived;
    long updateBytesTotal;

    static string FormatMb(long bytes) => (bytes / 1024.0 / 1024.0).ToString("N0");

    async Task CheckUpdate()
    {
        checkingUpdate = true;
        updateFailed = false;
        updateStatus = null;
        try
        {
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(30));
            var result = await Updater.CheckAsync(cts.Token);
            if (result.Available && result.Info is not null)
            {
                updateAvailable = true;
                updateInfo = result.Info;
                updatePhase = UpdatePhase.Idle;
            }
            else if (result.Error is not null)
            {
                updateFailed = true;
                updateStatus = result.Error;
            }
            else
            {
                updateStatus = $"You're on the latest version ({Updater.CurrentVersion.ToString(3)}).";
            }
        }
        catch (Exception ex)
        {
            updateFailed = true;
            updateStatus = $"Update check failed: {ex.Message}";
        }
        finally { checkingUpdate = false; }
    }

    async Task DownloadUpdate()
    {
        if (updateInfo is null) return;
        updateFailed = false;
        updatePhase = UpdatePhase.Downloading;
        updateBytesReceived = 0;
        updateBytesTotal = updateInfo.Size;
        updatePercent = updateInfo.Size > 0 ? 0 : -1;

        var progress = new Progress<UpdateProgress>(p =>
        {
            updatePhase = p.Phase;
            updateBytesReceived = p.BytesReceived;
            updateBytesTotal = p.TotalBytes;
            updatePercent = p.Percent;
            updateStatus = p.Phase switch
            {
                UpdatePhase.Downloading => "Downloading update…",
                UpdatePhase.Extracting => "Extracting…",
                UpdatePhase.Preparing => "Preparing…",
                UpdatePhase.ReadyToApply => "Ready to install",
                _ => updateStatus
            };
            InvokeAsync(StateHasChanged);
        });

        try
        {
            preparedUpdaterPath = await Updater.DownloadAndPrepareAsync(updateInfo, progress);
            updatePhase = UpdatePhase.ReadyToApply;
        }
        catch (Exception ex)
        {
            updateFailed = true;
            updatePhase = UpdatePhase.Idle;
            updateStatus = $"Update download failed: {ex.Message}";
        }
    }

    void ApplyUpdate()
    {
        if (preparedUpdaterPath is null) return;
        updatePhase = UpdatePhase.Applying;
        updateStatus = "Opening the installer…";
        Updater.ApplyAndExit(preparedUpdaterPath);
    }

    void DismissUpdate()
    {
        updatePhase = UpdatePhase.Idle;
        updateAvailable = false;
        updateInfo = null;
        preparedUpdaterPath = null;
        updateStatus = null;
    }

    void OpenUrl(string url)
    {
        try { Microsoft.Maui.ApplicationModel.Launcher.OpenAsync(new Uri(url)); } catch { }
    }

    string? preparedUpdaterPath;

    void Toggle(Action<Mesh.App.Domain.MeshProfile> change) => State.Mutate(change);

    async Task CreateInvite()
    {
        linkError = null;
        linkWorking = true;
        try
        {
            if (!Uri.TryCreate(State.Profile.RelayUrl, UriKind.Absolute, out var relayUri) ||
                (relayUri.Scheme != Uri.UriSchemeHttps && !(relayUri.Scheme == Uri.UriSchemeHttp && relayUri.IsLoopback)) ||
                !string.IsNullOrEmpty(relayUri.UserInfo) || !string.IsNullOrEmpty(relayUri.Query) ||
                !string.IsNullOrEmpty(relayUri.Fragment))
            {
                linkError = "A valid HTTPS relay URL is required before generating a device-link.";
                return;
            }
            var ttl = TimeSpan.FromMinutes(5);
            var (ok, code, err) = await Mesh.CreateLinkInviteAsync(ttl);
            if (!ok || code is null) { linkError = err ?? "Could not create invite."; return; }
            linkCode = code;
            var pairingUrl = UniversalLink.ForPairing(State.Profile.Handle, code, State.Profile.RelayUrl);
            qrDataUri = BuildQr(pairingUrl);
            remaining = (int)ttl.TotalSeconds;
            linkTimer = new System.Threading.Timer(_ =>
            {
                remaining--;
                if (remaining <= 0) { ClearInvite(); }
                InvokeAsync(StateHasChanged);
            }, null, 1000, 1000);
        }
        catch (Exception ex) { linkError = ex.Message; }
        finally { linkWorking = false; }
    }

    void ClearInvite()
    {
        linkTimer?.Dispose();
        linkTimer = null;
        linkCode = null;
        qrDataUri = null;
    }

    // HTTPS opens from a normal Camera app; the landing page immediately hands off to Mesh.
    string BuildQr(string payload)
    {
        using var gen = new QRCoder.QRCodeGenerator();
        using var data = gen.CreateQrCode(payload, QRCoder.QRCodeGenerator.ECCLevel.Q);
        var png = new QRCoder.PngByteQRCode(data).GetGraphic(6);
        return "data:image/png;base64," + Convert.ToBase64String(png);
    }

    public void Dispose()
    {
        linkTimer?.Dispose();
        State.Changed -= Refresh;
        Setup.Changed -= Refresh;
        Mesh.StateChanged -= Refresh;
        Foundry.ModelsChanged -= Refresh;
        Updater.Changed -= Refresh;
    }
}
