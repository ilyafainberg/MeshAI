@page "/skills"
@inject AppState State
@inject SkillMarketplaceService Marketplace
@implements IDisposable

<div class="pane-scroll">
    <div class="pane-narrow">
    <SectionHeader Title="Skills"
                   Description="Expose capabilities your agent can perform - share them with circles so guest agents can request them." />

    <div class="card-panel">
        <div class="field">
            <label>Skill name</label>
            <input class="full" @bind="name" placeholder="e.g. Book a 30-min intro call" />
        </div>
        <div class="field">
            <label>Description</label>
            <input class="full" @bind="description" placeholder="Short description of what it does" />
        </div>
        <div class="field">
            <label>Instructions <span class="muted">(how the agent performs it)</span></label>
            <textarea class="full" rows="3" @bind="instructions" placeholder="e.g. Offer two time slots and confirm the attendee's email…"></textarea>
        </div>
        <div class="field">
            <label>Who can use it</label>
            <select class="full" @bind="visibility">
                <option value="private">Private (owner only)</option>
                <option value="public">Public (any allowed contact)</option>
                @foreach (var c in State.Profile.Circles)
                {
                    <option value="@($"shared:{c.Name}")">Shared: @c.Name</option>
                }
            </select>
        </div>
        <button class="primary" @onclick="Add" disabled="@string.IsNullOrWhiteSpace(name)">
            <i class="bi bi-plus-lg"></i> Add skill
        </button>
    </div>

    <div class="card-panel">
        <div class="mp-title">
            <h3><i class="bi bi-shop"></i> Skill marketplaces</h3>
            <span class="field-hint">Connect a marketplace by URL, browse its skills, and import the ones you want. Add a bespoke skills.json, or a GitHub repo like owner/repo. Imported skills auto-update on startup.</span>
        </div>

        <div class="mp-add-row">
            <input class="full" placeholder="owner/repo or https://example.com/skills.json"
                   @bind="marketUrl" @bind:event="oninput" @onkeydown="OnMarketKeyDown" disabled="@addingMarket" />
            <button class="primary" @onclick="AddMarketplace" disabled="@(addingMarket || string.IsNullOrWhiteSpace(marketUrl))">
                @if (addingMarket)
                {
                    <i class="bi bi-arrow-repeat spin"></i> <span>Adding</span>
                }
                else
                {
                    <i class="bi bi-plus-lg"></i> <span>Add</span>
                }
            </button>
        </div>
        @if (!string.IsNullOrEmpty(marketError)) { <div class="err-text">@marketError</div> }

        @if (State.Profile.SkillMarketplaces.Count == 0)
        {
            <div class="muted small">No marketplaces yet. Add one to browse importable skills.</div>
        }
        else
        {
            <div class="mp-list">
                @foreach (var m in State.Profile.SkillMarketplaces)
                {
                    <div class="mp-row">
                        <div class="mp-info">
                            <b>@m.Name</b>
                            <span class="muted small">@HostOf(m.Url)</span>
                            @if (m.LastSyncedAt is not null)
                            {
                                <span class="muted small">Last synced @m.LastSyncedAt.Value.LocalDateTime.ToString("g")</span>
                            }
                        </div>
                        <div class="mp-actions">
                            <button class="ghost" @onclick="() => Browse(m)" disabled="@(browsingId == m.Id)">
                                @if (browsingId == m.Id)
                                {
                                    <i class="bi bi-arrow-repeat spin"></i> <span>Loading</span>
                                }
                                else
                                {
                                    <i class="bi bi-search"></i> <span>Browse</span>
                                }
                            </button>
                            <button class="ghost" @onclick="() => SyncNow(m)" disabled="@(syncingId == m.Id)">
                                @if (syncingId == m.Id)
                                {
                                    <i class="bi bi-arrow-repeat spin"></i> <span>Syncing</span>
                                }
                                else
                                {
                                    <i class="bi bi-arrow-repeat"></i> <span>Sync now</span>
                                }
                            </button>
                            <button class="icon-btn" title="Remove marketplace" @onclick="() => RemoveMarketplace(m)"><i class="bi bi-trash"></i></button>
                        </div>

                        @if (openMarketId == m.Id)
                        {
                            <div class="sk-modal-backdrop" @onclick="CloseBrowse">
                            <div class="sk-modal" @onclick:stopPropagation="true">
                            <div class="sk-modal-head">
                                <b><i class="bi bi-shop"></i> @m.Name</b>
                                <button class="icon-btn" title="Close" @onclick="CloseBrowse"><i class="bi bi-x-lg"></i></button>
                            </div>
                            <div class="sk-modal-body">
                                @if (browseError is not null)
                                {
                                    <div class="err-text">@browseError</div>
                                }
                                else if (browseIndex is null)
                                {
                                    <div class="muted small">Loading skills…</div>
                                }
                                else if (browseIndex.Skills.Count == 0)
                                {
                                    <div class="muted small">This marketplace offers no skills right now.</div>
                                }
                                else
                                {
                                    RenderFragment<SkillMarketplaceService.MarketplaceSkill> skillRow = ms =>
                                        @<label class="mp-skill @(IsImported(m.Id, ms.Id) ? "is-imported" : "")">
                                            <input type="checkbox" disabled="@IsImported(m.Id, ms.Id)"
                                                   checked="@selected.Contains(ms.Id)"
                                                   @onchange="e => ToggleSelected(ms.Id, e)" />
                                            <div class="mp-skill-body">
                                                <div class="mp-skill-head">
                                                    <b>@ms.Name</b>
                                                    @if (IsImported(m.Id, ms.Id)) { <span class="chip">Imported</span> }
                                                </div>
                                                @if (!string.IsNullOrWhiteSpace(ms.Description)) { <div class="muted small">@ms.Description</div> }
                                            </div>
                                        </label>;

                                    if (browseIndex.Plugins.Count > 0)
                                    {
                                        <div class="mp-plugin-list">
                                            @foreach (var pl in browseIndex.Plugins)
                                            {
                                                <div class="mp-plugin">
                                                    <div class="mp-plugin-head">
                                                        <i class="bi bi-box-seam"></i>
                                                        <b>@pl.Name</b>
                                                        <span class="muted small">@pl.Skills.Count skill@(pl.Skills.Count == 1 ? "" : "s")</span>
                                                    </div>
                                                    @if (!string.IsNullOrWhiteSpace(pl.Description)) { <div class="muted small mp-plugin-desc">@pl.Description</div> }
                                                    <div class="mp-skill-list">
                                                        @foreach (var ms in pl.Skills) { @skillRow(ms) }
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="mp-skill-list">
                                            @foreach (var ms in browseIndex.Skills) { @skillRow(ms) }
                                        </div>
                                    }
                                }
                            </div>
                            @if (browseError is null && browseIndex is not null && browseIndex.Skills.Count > 0)
                            {
                                <div class="sk-modal-foot">
                                    <button class="ghost" @onclick="CloseBrowse"><i class="bi bi-x-lg"></i> Close</button>
                                    <button class="primary" @onclick="() => ImportSelected(m)" disabled="@(selected.Count == 0)">
                                        <i class="bi bi-download"></i> Import selected (@selected.Count)
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="sk-modal-foot">
                                    <button class="ghost" @onclick="CloseBrowse"><i class="bi bi-x-lg"></i> Close</button>
                                </div>
                            }
                            </div>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <div class="kn-list">
        @if (State.Profile.Skills.Count == 0 && !skillHintDismissed)
        {
            <div class="kn-hint" role="note" aria-label="Getting started tip">
                <span class="kn-hint-text">Try "Book a 30-min intro call" - name a skill, describe it, write how your agent should handle it, then share it with a circle.</span>
                <button class="kn-hint-close" @onclick="() => skillHintDismissed = true" aria-label="Dismiss tip"><i class="bi bi-x-lg"></i></button>
            </div>
        }
        @foreach (var s in State.Profile.Skills)
        {
            <div class="kn-card">
                @if (editingId == s.Id)
                {
                    <div class="field">
                        <label>Name</label>
                        <input class="full" @bind="editName" />
                    </div>
                    <div class="field">
                        <label>Description</label>
                        <input class="full" @bind="editDescription" />
                    </div>
                    <div class="field">
                        <label>Instructions <span class="muted">(how the agent performs it)</span></label>
                        <textarea class="full" rows="6" @bind="editInstructions"></textarea>
                    </div>
                    <div class="kn-row">
                        <select @bind="editVisibility">
                            <option value="private">Private</option>
                            <option value="public">Public</option>
                            @foreach (var c in State.Profile.Circles)
                            {
                                <option value="@($"shared:{c.Name}")">Shared: @c.Name</option>
                            }
                        </select>
                        <button class="primary" @onclick="() => SaveEdit(s)"><i class="bi bi-check-lg"></i> Save</button>
                        <button class="ghost" @onclick="() => editingId = null"><i class="bi bi-x-lg"></i> Cancel</button>
                    </div>
                }
                else
                {
                    <div class="kn-head">
                        <label class="switch" title="Enabled">
                            <input type="checkbox" checked="@s.Enabled" @onchange="e => Toggle(s, e)" />
                        </label>
                        <b>@s.Name</b>
                        <span class="vis @VisClass(s.Visibility)">@s.Visibility</span>
                        @if (s.SourceMarketplaceId is not null)
                        {
                            <span class="mp-badge"><i class="bi bi-shop"></i> from @MarketNameFor(s.SourceMarketplaceId)</span>
                        }
                        <span class="spacer"></span>
                        <button class="icon-btn" title="Edit" @onclick="() => BeginEdit(s)"><i class="bi bi-pencil"></i></button>
                        <button class="icon-btn" title="Delete" @onclick="() => Remove(s)"><i class="bi bi-trash"></i></button>
                    </div>
                    <div class="kn-body">
                        @s.Description
                        @if (!string.IsNullOrWhiteSpace(s.Instructions)) { <div class="muted small">How: @s.Instructions</div> }
                    </div>
                }
            </div>
        }
        @if (State.Profile.Skills.Count == 0)
        {
            <EmptyState Icon="bi-lightning-charge"
                        Title="No skills yet"
                        Description="Add a skill and share it with a circle so guest agents can request it." />
        }
    </div>
    </div>
</div>

@code {
    string name = "", description = "", instructions = "", visibility = "private";
    string? editingId;
    string editName = "", editDescription = "", editInstructions = "", editVisibility = "private";
    bool skillHintDismissed;

    protected override void OnInitialized() => State.Changed += Refresh;
    void Refresh() => InvokeAsync(StateHasChanged);

    void Add()
    {
        if (string.IsNullOrWhiteSpace(name)) return;
        State.Mutate(p => p.Skills.Add(new Skill
        {
            Name = name.Trim(), Description = description.Trim(), Instructions = instructions.Trim(), Visibility = visibility
        }));
        name = ""; description = ""; instructions = ""; visibility = "private";
    }

    void BeginEdit(Skill s)
    {
        editingId = s.Id; editName = s.Name; editDescription = s.Description;
        editInstructions = s.Instructions; editVisibility = s.Visibility;
    }

    void SaveEdit(Skill s)
    {
        State.Mutate(_ =>
        {
            s.Name = editName.Trim(); s.Description = editDescription.Trim();
            s.Instructions = editInstructions.Trim(); s.Visibility = editVisibility;
        });
        editingId = null;
    }

    void Toggle(Skill s, ChangeEventArgs e) => State.Mutate(_ => s.Enabled = (bool)(e.Value ?? false));
    void Remove(Skill s) => State.Mutate(p => p.Skills.Remove(s));

    static string VisClass(string v) => v == "private" ? "priv" : v == "public" ? "pub" : "shared";

    // ---- Skill marketplaces ----
    string marketUrl = "";
    string? marketError;
    bool addingMarket;

    string? browsingId;                 // marketplace currently being fetched
    string? openMarketId;               // marketplace whose browse panel is open
    string? syncingId;                  // marketplace currently syncing
    SkillMarketplaceService.MarketplaceIndex? browseIndex;
    string? browseError;
    readonly HashSet<string> selected = new();

    async Task AddMarketplace()
    {
        if (addingMarket || string.IsNullOrWhiteSpace(marketUrl)) return;
        addingMarket = true;
        marketError = null;
        try
        {
            var (added, error) = await Marketplace.AddMarketplaceAsync(marketUrl);
            if (added is null) { marketError = error; }
            else { marketUrl = ""; }
        }
        finally { addingMarket = false; }
    }

    async Task OnMarketKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await AddMarketplace();
    }

    async Task Browse(SkillMarketplace m)
    {
        if (openMarketId == m.Id) { CloseBrowse(); return; }
        browsingId = m.Id;
        browseError = null;
        browseIndex = null;
        selected.Clear();
        openMarketId = m.Id;
        try
        {
            var (index, error) = await Marketplace.FetchAsync(m.Url);
            browseIndex = index;
            browseError = error;
        }
        finally { browsingId = null; }
    }

    void CloseBrowse()
    {
        openMarketId = null;
        browseIndex = null;
        browseError = null;
        selected.Clear();
    }

    void ToggleSelected(string skillId, ChangeEventArgs e)
    {
        if ((bool)(e.Value ?? false)) selected.Add(skillId);
        else selected.Remove(skillId);
    }

    void ImportSelected(SkillMarketplace m)
    {
        if (browseIndex is null || selected.Count == 0) return;
        Marketplace.ImportSkills(m.Id, browseIndex, selected.ToList());
        selected.Clear();
    }

    async Task SyncNow(SkillMarketplace m)
    {
        if (syncingId is not null) return;
        syncingId = m.Id;
        marketError = null;
        try
        {
            await Marketplace.SyncAllAsync();
        }
        finally { syncingId = null; }
    }

    void RemoveMarketplace(SkillMarketplace m)
    {
        if (openMarketId == m.Id) CloseBrowse();
        Marketplace.RemoveMarketplace(m.Id);
    }

    bool IsImported(string marketplaceId, string skillId)
        => State.Profile.Skills.Any(s => s.SourceMarketplaceId == marketplaceId && s.SourceSkillId == skillId);

    string MarketNameFor(string? marketplaceId)
    {
        var m = State.Profile.SkillMarketplaces.FirstOrDefault(x => x.Id == marketplaceId);
        return m?.Name ?? "marketplace";
    }

    static string HostOf(string url)
        => Uri.TryCreate(url, UriKind.Absolute, out var u) ? u.Host : url;

    public void Dispose() => State.Changed -= Refresh;
}
