@page "/"
@inject AppState State
@inject AgentService Agent
@inject AgentRunCoordinator Runs
@inject MeshClient Mesh
@inject LocalFileRegistry LocalFiles
@inject IJSRuntime JS
@inject NavigationManager Nav
@implements IDisposable

<div class="split">
    <div class="conv-list">
        <h2><i class="bi bi-person-badge"></i> Me</h2>
        <div class="new-conv">
            <span class="muted" style="flex:1;">your private topic chats</span>
            <button class="primary icon-primary" @onclick="NewThread" title="New chat" aria-label="New chat"><i class="bi bi-plus-lg"></i></button>
        </div>
        <div class="thread-order-list" @ref="threadListEl">
            @foreach (var t in Threads)
            {
                <div class="conv-item @(t.Id == activeThread ? "active" : "")" data-thread-id="@t.Id" @key="t.Id" @onclick="() => Select(t.Id)">
                    <button class="thread-grip" data-thread-grip type="button" title="Drag to reorder" aria-label="Drag @(string.IsNullOrWhiteSpace(t.Title) ? "New chat" : t.Title) to reorder" @onclick:stopPropagation="true">
                        <i class="bi bi-grip-vertical"></i>
                    </button>
                    <span class="conv-name">@(string.IsNullOrWhiteSpace(t.Title) ? "New chat" : t.Title)</span>
                    @if (State.IsThreadCompleted(t.Id)) { <span class="topic-unread" title="Agent finished" aria-label="Agent finished"></span> }
                </div>
            }
        </div>
        @if (State.Profile.OwnThreads.Count == 0)
        {
            <div class="empty conv-empty">No chats yet. Start one with the + above, or just type below.</div>
        }
    </div>

    <div class="thread">
        <header class="pane-head">
            @if (renaming && Active is not null)
            {
                <input class="rename-input" @bind="renameText" @bind:event="oninput" @onkeydown="OnRenameKey" aria-label="Chat title" />
                <button class="icon-btn" title="Save" @onclick="SaveRename" aria-label="Save title"><i class="bi bi-check-lg"></i></button>
                <button class="icon-btn" title="Cancel" @onclick="() => renaming = false" aria-label="Cancel rename"><i class="bi bi-x-lg"></i></button>
            }
            else
            {
                <h2>@(Active is null ? "Me" : (string.IsNullOrWhiteSpace(Active.Title) ? "New chat" : Active.Title))</h2>
                <span class="muted">your agent sees everything you know</span>
            }
            <span style="margin-left:auto; display:flex; align-items:center; gap:6px;">
                <TokenMeter Compact="true" />
                @if (Active is not null && !renaming)
                {
                    <button class="ghost icon-btn" title="Rename chat" aria-label="Rename chat" @onclick="BeginRename"><i class="bi bi-pencil"></i></button>
                    @if (confirmDelete)
                    {
                        <button class="ghost icon-btn" title="Clear messages, keep the chat" @onclick="ClearActive">Clear</button>
                        <button class="danger" title="Delete this chat and its history" @onclick="DeleteActive">Delete</button>
                        <button class="ghost icon-btn" title="Cancel" @onclick="() => confirmDelete = false" aria-label="Cancel"><i class="bi bi-x-lg"></i></button>
                    }
                    else
                    {
                        <button class="ghost icon-btn" title="Report AI content" aria-label="Report AI content" @onclick="OpenReport"><i class="bi bi-flag"></i></button>
                        <button class="ghost icon-btn" title="Delete chat" aria-label="Delete chat" @onclick="() => confirmDelete = true"><i class="bi bi-trash"></i></button>
                    }
                }
            </span>
        </header>

        <div class="messages" @ref="scrollEl">
            <div class="messages-wrap">
                @if (Active is null || Active.Lines.Count == 0)
                {
                    <div class="empty">
                        This is your private assistant. It knows everything in your Knowledge and Skills,
                        and helps you manage what your public agent shares with others. Ask it anything.
                    </div>
                }
                @if (Active is not null)
                {
                    @foreach (var line in Active.Lines.Where(l => !l.Internal))
                    {
                        <div class="bubble @(line.Role)">
                            @if (!string.IsNullOrEmpty(line.Reasoning))
                            {
                                <button class="reasoning-toggle" @onclick="() => ToggleReasoning(line)" aria-label="Show reasoning">
                                    <i class="bi bi-lightbulb"></i>
                                    <span>Reasoning</span>
                                    <i class="bi @(expandedReasoning.Contains(line) ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                </button>
                                @if (expandedReasoning.Contains(line))
                                {
                                    <div class="reasoning-body">@((MarkupString)Markdown.ToHtml(line.Reasoning!))</div>
                                }
                            }
                            <MessageContent Text="@line.Text" Attachments="@line.Attachments"
                                            OnPin="html => PinWidget(html, line)" />
                            @if (line.Via == "home-agent")
                            {
                                <div class="msg-tag home-agent-tag"><i class="bi bi-house-gear"></i> Home Agent</div>
                            }
                            @if (IsQueued(line))
                            {
                                <div class="msg-tag"><i class="bi bi-hourglass-split"></i> queued</div>
                            }
                        </div>
                    }
                }
                @if (ActiveBusy)
                {
                    <div class="bubble assistant">
                        @{ var run = Active is null ? null : State.AgentRunFor(Active.Id); }
                        @if (run is not null)
                        {
                            @if (run.Phase == AgentRunPhase.Planning)
                            {
                                <div class="planning-row"><i class="bi bi-diagram-3"></i> Planning</div>
                            }
                            else
                            {
                                <div class="text md">@((MarkupString)Markdown.ToHtml(run.Plan))</div>
                                <div class="msg-tag"><i class="bi bi-diagram-3"></i> @run.Phase.ToString().ToLowerInvariant()</div>
                            }
                        }
                        @{ var steps = Active is null ? null : State.AgentStepsFor(Active.Id); }
                        @if (steps is { Count: > 0 })
                        {
                            <div class="agent-steps">
                                @foreach (var s in steps)
                                {
                                    <div class="agent-step-item">
                                        <div class="agent-step @s.State.ToString().ToLowerInvariant()">
                                            <i class="bi @StepIcon(s.State)"></i>
                                            <span>@s.Label</span>
                                        </div>
                                        @if (showStepDetails && (!string.IsNullOrEmpty(s.Arguments) || !string.IsNullOrEmpty(s.Result)))
                                        {
                                            <div class="agent-step-detail">
                                                @if (!string.IsNullOrEmpty(s.Arguments))
                                                {
                                                    <div class="step-detail-label">input</div>
                                                    <pre class="step-detail-body">@s.Arguments</pre>
                                                }
                                                @if (!string.IsNullOrEmpty(s.Result))
                                                {
                                                    <div class="step-detail-label">output</div>
                                                    <pre class="step-detail-body">@s.Result</pre>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                            <button class="step-details-toggle" @onclick="() => showStepDetails = !showStepDetails">
                                <i class="bi @(showStepDetails ? "bi-chevron-up" : "bi-chevron-down")"></i>
                                @(showStepDetails ? "Hide details" : "Show details")
                            </button>
                        }
                        @if (run?.Phase != AgentRunPhase.Planning)
                        {
                            <div class="text muted">@(ActiveBuilding ? "…building widget" : "…thinking")</div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="composer-area">
            <div class="composer-inner">
                @if (pinHtml is not null)
                {
                    <div class="pin-bar">
                        <i class="bi bi-pin-angle"></i>
                        <input @bind="pinName" placeholder="Name this widget…" @onkeydown="OnPinKey" aria-label="Name this widget" />
                        <button class="primary" @onclick="ConfirmPin" disabled="@string.IsNullOrWhiteSpace(pinName)">Pin</button>
                        <button class="ghost icon-btn" @onclick="() => { pinHtml = null; pinError = null; }" title="Cancel" aria-label="Cancel"><i class="bi bi-x-lg"></i></button>
                    </div>
                    @if (pinError is not null) { <p class="err-text" role="alert">@pinError</p> }
                }
                @if (widgetMode)
                {
                    <div class="mode-chip">
                        <i class="bi bi-window-stack"></i> widget
                        <button class="chip-x" @onclick="ClearWidgetMode" title="Cancel widget" aria-label="Cancel widget"><i class="bi bi-x"></i></button>
                        <span class="mode-hint">describe the mini-app you want</span>
                    </div>
                }
                else if (selectedWidget is not null)
                {
                    <div class="mode-chip selected-widget-chip">
                        <i class="bi bi-window-stack"></i>
                        <span class="widget-chip-name">@selectedWidget.Name</span>
                        <button class="chip-x" @onclick="ClearWidgetMode" title="Remove widget" aria-label="Remove selected widget"><i class="bi bi-x"></i></button>
                        <span class="mode-hint">send to use, or describe changes</span>
                    </div>
                }
                else if (ShowPreview)
                {
                    <div class="composer-preview">
                        <span class="preview-label"><i class="bi bi-eye"></i> preview</span>
                        <div class="text md">@((MarkupString)Markdown.ToHtml(input))</div>
                    </div>
                }
                @if (attachments.Count > 0)
                {
                    <div class="attach-bar">
                        @foreach (var a in attachments)
                        {
                            <span class="attach-chip">
                                <i class="bi bi-paperclip"></i>
                                <span class="attach-name">@a.Name</span>
                                <span class="attach-size">@a.SizeLabel</span>
                                <button class="chip-x" @onclick="() => attachments.Remove(a)" title="Remove" aria-label="Remove attachment"><i class="bi bi-x"></i></button>
                            </span>
                        }
                    </div>
                }
                <div class="composer">
                    <div class="widget-picker-anchor">
                        <button class="ghost icon-btn plus-btn @(widgetMode || selectedWidget is not null || widgetPickerOpen ? "on" : "")"
                                @onclick="ToggleWidgetPicker" disabled="@ActiveBusy" title="Create or choose a widget"
                                aria-label="Create or choose a widget" aria-haspopup="menu" aria-expanded="@widgetPickerOpen"
                                aria-controls="home-widget-picker">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                        @if (widgetPickerOpen)
                        {
                            <div id="home-widget-picker" class="widget-picker" role="menu" aria-label="Choose a widget">
                                <button class="widget-picker-item widget-picker-create" role="menuitem" @onclick="CreateNewWidget">
                                    <i class="bi bi-magic"></i>
                                    <span>Create new widget</span>
                                </button>
                                <div class="widget-picker-separator" role="separator"></div>
                                @if (State.Profile.Widgets.Count == 0)
                                {
                                    <div class="widget-picker-empty">No saved widgets yet</div>
                                }
                                else
                                {
                                    <div class="widget-picker-list">
                                        @foreach (var widget in State.Profile.Widgets)
                                        {
                                            <button class="widget-picker-item" role="menuitem" @onclick="() => SelectWidget(widget)" @key="widget.Id">
                                                <i class="bi bi-window-stack"></i>
                                                <span>@widget.Name</span>
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                    <button class="ghost icon-btn plus-btn" @onclick="PickFile" disabled="@ActiveBusy" title="Attach an image or document" aria-label="Attach an image or document">
                        <i class="bi bi-paperclip"></i>
                    </button>
                    @if (PlatformCaps.IsMobile)
                    {
                        <button class="ghost icon-btn plus-btn @(homeMode ? "on" : "")" @onclick="() => homeMode = !homeMode" disabled="@ActiveBusy"
                                title="Ask my home agent (runs on my desktop with full tools)" aria-label="Ask my home agent">
                            <i class="bi bi-house-gear"></i>
                        </button>
                    }
                    <textarea @ref="composerEl" @bind="input" @bind:event="oninput" rows="1" class="composer-input"
                              placeholder="@ComposerPlaceholder" aria-label="@ComposerAriaLabel"></textarea>
                    @if (ActiveBusy)
                    {
                        <button class="primary send-btn stop-btn" @onclick="StopActive" title="Stop" aria-label="Stop">
                            <i class="bi bi-stop-fill"></i>
                        </button>
                    }
                    else
                    {
                        <button class="primary send-btn" @onclick="Send" disabled="@(string.IsNullOrWhiteSpace(input) && attachments.Count == 0 && selectedWidget is null)" title="Send" aria-label="Send">
                            <i class="bi @(widgetMode || selectedWidget is not null ? "bi-magic" : "bi-send")"></i>
                        </button>
                    }
                </div>
                @if (attachError is not null) { <p class="err-text">@attachError</p> }
                @if (!Agent.IsModelReady)
                {
                    <div class="warn-banner"><i class="bi bi-exclamation-triangle"></i> No model configured. Go to <a href="settings">Settings</a>.</div>
                }
                else if (QuotaExhausted)
                {
                    <div class="warn-banner">
                        <i class="bi bi-hourglass-bottom"></i>
                        Today's free-model limit is reached. <a href="settings">Add your own model key</a> for unlimited use, or switch to an on-device model.
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<ReportDialog @ref="reportDialog" />

@code {
    string input = "";
    // Per-thread run state (busy/building/queue) lives in AppState (the singleton), NOT here, so a
    // running turn and its thinking indicator survive navigating away from and back to the Me section,
    // and a fresh page instance never starts a second concurrent turn for an already-running thread.
    bool widgetMode;
    bool widgetPickerOpen;
    Widget? selectedWidget;
    bool homeMode;
    bool confirmDelete;
    bool renaming;
    string renameText = "";
    string? activeThread;
    ReportDialog? reportDialog;
    string? pinHtml;
    string pinName = "";
    string? pinPrompt;
    string? pinError;
    ElementReference scrollEl;
    ElementReference composerEl;
    ElementReference threadListEl;
    Microsoft.JSInterop.DotNetObjectReference<Home>? selfRef;
    bool composerWired;
    int lastCount = -1;
    bool lastBusy;
    bool disposed;

    // True when the thread currently being viewed is running a turn (drives the composer + thinking bubble).
    bool ActiveBusy => Active is not null && State.IsThreadBusy(Active.Id);
    bool ActiveBuilding => Active is not null && State.IsThreadBuilding(Active.Id);
    string ComposerPlaceholder => homeMode
        ? "Message your home assistant..."
        : widgetMode
        ? "Describe the widget you want…"
        : selectedWidget is not null
            ? $"Use or change {selectedWidget.Name}…"
            : "Message your assistant…";
    string ComposerAriaLabel => homeMode ? "Message your home assistant" : "Message your assistant";

    readonly List<StagedFile> attachments = new();
    string? attachError;

    // Assistant lines whose reasoning ("thinking") section is currently expanded.
    readonly HashSet<ChatLine> expandedReasoning = new();

    // When true, the live step trace shows each tool's raw arguments and output (verbose mode).
    bool showStepDetails;

    void ToggleReasoning(ChatLine line)
    {
        if (!expandedReasoning.Remove(line)) expandedReasoning.Add(line);
    }

    static string StepIcon(AgentStepState state) => state switch
    {
        AgentStepState.Started => "bi-arrow-repeat spin",
        AgentStepState.Done => "bi-check2",
        AgentStepState.Failed => "bi-exclamation-triangle",
        _ => "bi-dot"
    };

    static string HomeAgentFailure(string code) => code.ToLowerInvariant() switch
    {
        "home_device_required" or "no-target" or "no_target" or "no-home-device" => "Select an online desktop in Settings first.",
        "home_device_offline" or "offline" or "target-offline" or "target_offline" => "Your selected Home device is offline.",
        "home_device_not_eligible" or "disabled" or "target-disabled" or "target_disabled" => "Home Agent is unavailable on the selected desktop.",
        "not_connected" or "disconnected" or "not-connected" or "relay-disconnected" or "unreachable" => "Could not reach your Home device. Check its connection.",
        "rejected" => "Your Home device rejected the request.",
        _ => "Could not send this request to your Home device."
    };

    // Tier-1 steerable input: messages submitted while a thread's turn is running are queued for that
    // thread (shown immediately as a subtle "queued" line) and answered together in ONE follow-up turn
    // after the current one finishes, in order. A thread never runs two of its own turns concurrently,
    // but different threads run independently.
    bool IsQueued(ChatLine line) => State.IsLineQueued(line);

    sealed record StagedFile(string Name, string Path, long Size)
    {
        public string SizeLabel => Human(Size);
    }

    IReadOnlyList<OwnThread> Threads => State.Profile.OwnThreads;
    OwnThread? Active => activeThread is null ? null : State.Profile.OwnThreads.FirstOrDefault(t => t.Id == activeThread);

    bool ShowPreview => !string.IsNullOrWhiteSpace(input) && Markdown.LooksLikeMarkdown(input);

    // The free model returns a friendly limit message when the daily token budget is spent.
    bool QuotaExhausted
    {
        get
        {
            if (State.Profile.Model.Provider != global::Mesh.App.Domain.ModelProvider.MeshHosted) return false;
            var last = Active?.Lines.LastOrDefault(l => l.Role == "assistant");
            return last is not null && last.Text.StartsWith("You've reached today's free-model limit", StringComparison.Ordinal);
        }
    }

    protected override void OnInitialized()
    {
        State.Changed += Refresh;
        // Deep-link: /?thread=id opens that topic (used by Search). Otherwise land in the most recent.
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var wanted = ParseQueryValue(uri.Query, "thread");
        if (!string.IsNullOrWhiteSpace(wanted) && State.Profile.OwnThreads.Any(t => t.Id == wanted))
            activeThread = wanted;
        else if (activeThread is null && State.Profile.OwnThreads.Count > 0)
            activeThread = State.Profile.OwnThreads[^1].Id;
        if (activeThread is not null) State.MarkThreadSeen(activeThread);
    }

    static string? ParseQueryValue(string queryString, string key)
    {
        if (string.IsNullOrEmpty(queryString)) return null;
        foreach (var pair in queryString.TrimStart('?').Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var eq = pair.IndexOf('=');
            if (eq <= 0) continue;
            if (Uri.UnescapeDataString(pair[..eq]) == key) return Uri.UnescapeDataString(pair[(eq + 1)..]);
        }
        return null;
    }

    void Refresh() => InvokeAsync(StateHasChanged);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            selfRef = Microsoft.JSInterop.DotNetObjectReference.Create(this);

        // Wire each helper when its element actually exists. On mobile the list and composer are
        // mutually exclusive, so firstRender alone cannot initialize both.
        if (selfRef is not null)
        {
            if (!composerWired)
            {
                try
                {
                    await JS.InvokeVoidAsync("meshUI.composer", composerEl, selfRef, 5);
                    await JS.InvokeVoidAsync("meshPaste.attach", composerEl, selfRef);
                    composerWired = true;
                }
                catch { }
            }
            try { await JS.InvokeVoidAsync("meshUI.threadReorder", threadListEl, selfRef); } catch { }
        }

        // Scroll on first paint, when a line is added, AND when the active thread's turn finishes
        // (busy true->false): the reply is added while the thread is still busy, so tracking that
        // transition guarantees the final answer scrolls into view even if its line count collides
        // with an earlier render.
        var count = Active?.Lines.Count ?? 0;
        if (firstRender || count != lastCount || ActiveBusy != lastBusy || ActiveBusy)
        {
            lastCount = count;
            lastBusy = ActiveBusy;
            // autoScroll is idempotent: it attaches the sticky observer the first time scrollEl is real,
            // then keeps the pane pinned to the bottom as the step trace and reply grow.
            try { await JS.InvokeVoidAsync("meshUI.autoScroll", scrollEl); } catch { }
            try { await JS.InvokeVoidAsync("meshUI.scrollToBottom", scrollEl); } catch { }
        }
    }

    /// <summary>Invoked from JS when the user presses Enter (without Shift) in the composer.</summary>
    [Microsoft.JSInterop.JSInvokable]
    public Task SendFromComposer() => Send();

    /// <summary>
    /// Invoked from paste.js when a file is pasted into the composer. Writes the pasted bytes to a temp
    /// file and stages it so it sends by path (the same flow as the attach button), then re-renders.
    /// </summary>
    [Microsoft.JSInterop.JSInvokable]
    public Task OnPasteFile(string name, string mime, string base64)
    {
        attachError = null;
        var staged = PasteFiles.SaveTemp(name, mime, base64);
        if (staged is { } s)
        {
            LocalFiles.Allow(s.Path);
            attachments.Add(new StagedFile(s.Name, s.Path, s.Size));
        }
        else
        {
            attachError = "Could not read the pasted file.";
        }
        return InvokeAsync(StateHasChanged);
    }

    [Microsoft.JSInterop.JSInvokable]
    public Task ReorderThread(string draggedId, string targetId, bool before)
    {
        var from = State.Profile.OwnThreads.FindIndex(t => t.Id == draggedId);
        var target = State.Profile.OwnThreads.FindIndex(t => t.Id == targetId);
        if (from < 0 || target < 0 || from == target) return Task.CompletedTask;
        var destination = target + (before ? 0 : 1);
        if (from < destination) destination--;
        State.ReorderOwnThread(draggedId, destination);
        return InvokeAsync(StateHasChanged);
    }

    void Select(string id)
    {
        activeThread = id;
        confirmDelete = false;
        renaming = false;
        State.MarkThreadSeen(id);
    }

    void OpenReport()
    {
        if (Active is null) return;
        reportDialog?.Show($"Me topic: {Active.Title}", Active.Lines,
            l => l.Role == "assistant" ? "agent" : "me", State.CurrentModelKey());
    }

    void NewThread()
    {
        var t = State.NewOwnThread();
        activeThread = t.Id;
        confirmDelete = false;
        renaming = false;
        input = "";
    }

    void BeginRename()
    {
        if (Active is null) return;
        renameText = Active.Title;
        renaming = true;
    }

    void OnRenameKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") SaveRename();
        else if (e.Key == "Escape") renaming = false;
    }

    void SaveRename()
    {
        if (Active is not null) State.RenameOwnThread(Active.Id, renameText);
        renaming = false;
    }

    void ClearActive()
    {
        if (Active is not null) State.ClearOwnThread(Active.Id);
        confirmDelete = false;
    }

    void DeleteActive()
    {
        if (Active is null) return;
        var id = Active.Id;
        confirmDelete = false;
        State.DeleteOwnThread(id);
        activeThread = State.Profile.OwnThreads.Count > 0 ? State.Profile.OwnThreads[^1].Id : null;
    }

    void ToggleWidgetPicker() => widgetPickerOpen = !widgetPickerOpen;

    void CreateNewWidget()
    {
        widgetPickerOpen = false;
        selectedWidget = null;
        widgetMode = true;
    }

    void SelectWidget(Widget widget)
    {
        widgetPickerOpen = false;
        widgetMode = false;
        selectedWidget = widget;
    }

    void ClearWidgetMode()
    {
        widgetPickerOpen = false;
        widgetMode = false;
        selectedWidget = null;
    }

    async Task ResetComposer()
    {
        try { await JS.InvokeVoidAsync("meshUI.resetComposer", composerEl); } catch { }
    }

    async Task PickFile()
    {
        attachError = null;
        try
        {
            var file = await Microsoft.Maui.Storage.FilePicker.Default.PickAsync();
            if (file is null) return;
            var path = file.FullPath;
            if (string.IsNullOrWhiteSpace(path) || !System.IO.File.Exists(path))
            {
                attachError = "Could not resolve that file's path on disk.";
                return;
            }
            long size = 0;
            try { size = new System.IO.FileInfo(path).Length; } catch { }
            LocalFiles.Allow(path);
            attachments.Add(new StagedFile(file.FileName, path, size));
        }
        catch (Exception ex) { attachError = "Couldn't attach that file: " + ex.Message; }
    }

    static string Human(long bytes)
    {
        string[] units = { "B", "KB", "MB", "GB" };
        double size = bytes;
        int u = 0;
        while (size >= 1024 && u < units.Length - 1) { size /= 1024; u++; }
        return $"{size:0.#} {units[u]}";
    }

    // Stops the active thread's running turn. Cancellation flows into the agent call and the provider
    // tool loop, so the in-flight model request is actually aborted (not just hidden).
    void StopActive()
    {
        if (Active is not null) State.CancelThreadTurn(Active.Id);
    }

    async Task Send()
    {
        if (string.IsNullOrWhiteSpace(input) && attachments.Count == 0 && selectedWidget is null) return;

        // Ensure there is a thread to write into, and name a fresh one after its first message.
        var thread = Active ?? State.NewOwnThread();
        activeThread = thread.Id;
        var text = input;
        var chosenWidget = selectedWidget;
        var titleText = !string.IsNullOrWhiteSpace(text)
            ? text
            : chosenWidget is not null ? $"Use widget: {chosenWidget.Name}" : "";
        if (string.Equals(thread.Title, "New chat", StringComparison.Ordinal) && !string.IsNullOrWhiteSpace(titleText))
            State.RenameOwnThread(thread.Id, Titleize(titleText));

        var files = attachments.ToList();
        // Capture the composer modes now, since they are reset immediately and the turn runs async.
        var wasWidget = widgetMode;
        var wasHome = homeMode;
        input = "";
        attachments.Clear();
        widgetMode = false;
        homeMode = false;
        widgetPickerOpen = false;
        selectedWidget = null;
        _ = ResetComposer();

        // This thread is already running a turn: queue this input for its next turn instead of
        // starting a second concurrent call in the SAME thread. Show it immediately as a subtle
        // "queued" user line; it is already in the thread history, so the drain answers it in order.
        // Other threads are unaffected and keep running independently. The busy check is against the
        // shared app state, so a page instance reopened mid-turn still queues instead of double-running.
        if (State.IsThreadBusy(thread.Id))
        {
            // Widget creation/refinement is typed work, not a generic agent continuation. Preserve
            // the composer state instead of degrading it into the normal queued-chat path.
            if (wasWidget || chosenWidget is not null)
            {
                input = text;
                attachments.AddRange(files);
                widgetMode = wasWidget;
                selectedWidget = chosenWidget;
                attachError = "Wait for the current turn to finish before using or changing a widget.";
                return;
            }
            var queuedImages = await LoadImageAttachmentsAsync(files, CancellationToken.None);
            var qLine = new ChatLine
            {
                Role = "user",
                Text = chosenWidget is null
                    ? ComposeOwnerPrompt(text, files, queuedImages)
                    : ComposeQueuedWidgetPrompt(chosenWidget, text, files, queuedImages),
                Attachments = queuedImages
            };
            State.AddOwnChatLine(thread.Id, qLine);
            State.EnqueueForThread(thread.Id, qLine);
            return;
        }

        // Run this thread's turn WITHOUT awaiting it here, so sending in one Me topic never blocks
        // (or visually freezes) another. Each thread manages its own busy state and queue drain.
        _ = RunThreadTurnAsync(thread.Id, text, files, wasWidget, wasHome, chosenWidget);
    }

    // Runs one owner turn for a single thread, then drains that thread's queue. Independent of any
    // other thread's turn (service scopes flow via AsyncLocal, so concurrent turns do not mix). Run
    // state lives in AppState, so this task keeps the indicator correct even if the Me page is closed
    // (navigated away) mid-turn; it only touches singletons, so it is safe after component disposal.
    async Task RunThreadTurnAsync(string threadId, string text, List<StagedFile> files, bool widget, bool home, Widget? existingWidget)
    {
        var existingWidgetId = existingWidget?.Id;
        var existingWidgetName = existingWidget?.Name;
        var existingWidgetPrompt = existingWidget?.Prompt;
        var existingWidgetHtml = existingWidget?.Html;
        var ct = State.BeginThreadTurn(threadId, widget || existingWidget is not null);
        try
        {
            var imageFiles = await LoadImageAttachmentsAsync(files, ct);
            Runs.Start(threadId, text, imageFiles.Count > 0, widget || existingWidget is not null);
            Runs.Executing(threadId);
            if (existingWidget is not null && string.IsNullOrWhiteSpace(text) && files.Count == 0)
            {
                State.AddOwnChatLine(threadId, new ChatLine { Role = "user", Text = $"Use widget: {existingWidgetName}" });
                State.AddOwnChatLine(threadId, new ChatLine
                {
                    Role = "assistant",
                    Text = AsWidgetResponse(existingWidgetHtml!),
                    WidgetPrompt = existingWidgetPrompt
                });
            }
            else if (existingWidget is not null && (!string.IsNullOrWhiteSpace(text) || files.Count > 0))
            {
                var changeRequest = ComposeOwnerPrompt(text, files, imageFiles);
                State.AddOwnChatLine(threadId, new ChatLine
                {
                    Role = "user",
                    Text = $"Update widget {existingWidgetName}: {changeRequest}",
                    Attachments = imageFiles
                });
                var result = await Agent.RefineWidgetAsync(existingWidgetPrompt!, changeRequest, ct);
                var combinedPrompt = CombineWidgetPrompt(existingWidgetPrompt!, changeRequest);
                var appSegment = Markdown.Parse(result).FirstOrDefault(segment => segment.IsApp);
                State.AddOwnChatLine(threadId, new ChatLine
                {
                    Role = "assistant",
                    Text = result,
                    WidgetPrompt = appSegment is not null ? combinedPrompt : existingWidgetPrompt
                });
                if (appSegment is not null)
                {
                    var savedUpdateApplied = false;
                    State.Mutate(profile =>
                    {
                        var saved = profile.Widgets.FirstOrDefault(w => w.Id == existingWidgetId);
                        if (saved is null) return;
                        if (!string.Equals(saved.Prompt, existingWidgetPrompt, StringComparison.Ordinal)
                            || !string.Equals(saved.Html, existingWidgetHtml, StringComparison.Ordinal))
                            return;
                        saved.PreviousHtml = saved.Html;
                        saved.PreviousPrompt = saved.Prompt;
                        saved.Html = appSegment.Content;
                        saved.Prompt = combinedPrompt;
                        saved.ModifiedAt = DateTimeOffset.UtcNow;
                        savedUpdateApplied = true;
                    });
                    if (!savedUpdateApplied)
                        State.AddOwnChatLine(threadId, new ChatLine
                        {
                            Role = "assistant",
                            Text = "[This widget changed in another chat while the refinement was running, so this version was not saved.]"
                        });
                }
            }
            else if (widget)
            {
                var html = await Agent.BuildWidgetAsync(text, ct);
                State.AddOwnChatLine(threadId, new ChatLine { Role = "user", Text = $"Build a widget: {text}" });
                State.AddOwnChatLine(threadId, new ChatLine { Role = "assistant", Text = html, WidgetPrompt = text });
            }
            else if (home)
            {
                State.AddOwnChatLine(threadId, new ChatLine { Role = "user", Text = text, Via = "home-agent" });
                try
                {
                    var result = await Mesh.AskHomeAgentAsync(threadId, text, ct);
                    if (!result.Accepted)
                    {
                        State.AddOwnChatLine(threadId, new ChatLine
                        {
                            Role = "assistant",
                            Text = HomeAgentFailure(result.Code),
                            Via = "home-agent"
                        });
                    }
                }
                catch (OperationCanceledException) { throw; }
                catch
                {
                    State.AddOwnChatLine(threadId, new ChatLine
                    {
                        Role = "assistant",
                        Text = "Could not reach your Home device. Check its connection.",
                        Via = "home-agent"
                    });
                }
            }

            else
            {
                await Agent.AskAsOwnerAsync(threadId, ComposeOwnerPrompt(text, files, imageFiles), imageFiles, ct);
            }

            // Drain anything this thread queued while its turn ran. Each drain answers ALL of the
            // thread's currently queued lines together in one continuation turn (they are consecutive
            // user turns already in the history); loop in case more were queued while draining.
            while (!ct.IsCancellationRequested && State.QueuedCountForThread(threadId) > 0)
            {
                State.ClearThreadQueue(threadId); // they are now being answered, not waiting
                State.ClearThreadBuilding(threadId);
                await Agent.ContinueAsOwnerAsync(threadId, ct);
            }
        }
        catch (OperationCanceledException)
        {
            Runs.Complete(threadId, cancelled: true);
            // The user pressed Stop. Cancellation of the running model request and tool loop is
            // intentional, so record a clean stopped line rather than an error.
            State.AddOwnChatLine(threadId, new ChatLine { Role = "assistant", Text = "[stopped]" });
        }
        catch (Exception ex)
        {
            Runs.Complete(threadId, failed: true);
            State.AddOwnChatLine(threadId, new ChatLine { Role = "assistant", Text = $"[error: {ex.Message}]" });
        }
        finally
        {
            Runs.Complete(threadId);
            State.EndThreadTurn(threadId);
            if (disposed || activeThread != threadId)
                State.MarkThreadCompleted(threadId);
            else
                State.MarkThreadSeen(threadId);
        }
    }

    private static readonly Dictionary<string, string> ImageMimes = new(StringComparer.OrdinalIgnoreCase)
    {
        [".png"] = "image/png", [".jpg"] = "image/jpeg", [".jpeg"] = "image/jpeg",
        [".gif"] = "image/gif", [".webp"] = "image/webp", [".bmp"] = "image/bmp"
    };

    static async Task<List<ChatAttachment>> LoadImageAttachmentsAsync(List<StagedFile> files, CancellationToken ct)
    {
        const long maxImageBytes = 20 * 1024 * 1024;
        var images = new List<ChatAttachment>();
        foreach (var file in files)
        {
            if (!ImageMimes.TryGetValue(System.IO.Path.GetExtension(file.Path), out var mime)) continue;
            if (file.Size > maxImageBytes) throw new InvalidOperationException($"{file.Name} is larger than the 20 MB image limit.");
            var bytes = await System.IO.File.ReadAllBytesAsync(file.Path, ct);
            images.Add(new ChatAttachment(file.Name, mime, bytes));
        }
        return images;
    }

    // Non-images remain tool-readable paths. Images are sent as original bytes to the model and are
    // intentionally omitted here, preventing the agent from launching Photos and taking a screenshot.
    static string ComposeOwnerPrompt(string? text, List<StagedFile> files, IReadOnlyList<ChatAttachment>? images = null)
    {
        var prompt = text ?? "";
        var imageNames = images?.Select(i => i.Name).ToHashSet(StringComparer.OrdinalIgnoreCase) ?? new();
        var documents = files.Where(f => !imageNames.Contains(f.Name)).ToList();
        if (documents.Count > 0)
        {
            var sb = new System.Text.StringBuilder(prompt);
            if (sb.Length > 0) sb.Append("\n\n");
            sb.Append("Attached local files (use the read_local_file tool to open any you need):");
            foreach (var f in documents) sb.Append($"\n- {f.Path}");
            prompt = sb.ToString();
        }
        return prompt;
    }

    static string ComposeQueuedWidgetPrompt(Widget widget, string text, List<StagedFile> files, IReadOnlyList<ChatAttachment> images)
    {
        var request = ComposeOwnerPrompt(text, files, images);
        return string.IsNullOrWhiteSpace(request)
            ? $"Use saved widget \"{widget.Name}\". Its canonical prompt is: {widget.Prompt}"
            : $"Update saved widget \"{widget.Name}\". Canonical prompt: {widget.Prompt}\n\nChange request: {request}";
    }

    static string CombineWidgetPrompt(string canonicalPrompt, string changeRequest) =>
        string.IsNullOrWhiteSpace(canonicalPrompt) ? changeRequest : $"{canonicalPrompt}; {changeRequest}";

    static string AsWidgetResponse(string html) =>
        Markdown.Parse(html).Any(segment => segment.IsApp) ? html : $"```html-app\n{html}\n```";

    // A short title from the first message of a new chat.
    static string Titleize(string text)
    {
        var clean = text.Replace("\r", " ").Replace("\n", " ").Trim();
        if (clean.Length == 0) return "New chat";
        return clean.Length > 40 ? clean[..40].TrimEnd() + "…" : clean;
    }

    void PinWidget(string html, ChatLine line)
    {
        pinHtml = html;
        pinName = "";
        pinPrompt = line.WidgetPrompt;
        pinError = null;
    }

    void OnPinKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(pinName)) ConfirmPin();
    }

    void ConfirmPin()
    {
        if (pinHtml is null || string.IsNullOrWhiteSpace(pinName)) return;
        var name = pinName.Trim();
        if (State.Profile.Widgets.Any(w => string.Equals(w.Name, name, StringComparison.OrdinalIgnoreCase)))
        {
            pinError = $"A widget named \"{name}\" already exists. Choose a different name.";
            return;
        }
        State.Mutate(p => p.Widgets.Add(new Widget
        {
            Name = name,
            Html = pinHtml!,
            Prompt = pinPrompt ?? "Pinned from conversation",
            Visibility = "private",
            ModifiedAt = DateTimeOffset.UtcNow,
        }));
        pinHtml = null;
        pinName = "";
        pinPrompt = null;
        pinError = null;
    }

    public void Dispose()
    {
        disposed = true;
        State.Changed -= Refresh;
        selfRef?.Dispose();
    }
}
