@page "/community"
@inject DirectoryClient Dir
@inject MeshClient Mesh
@inject AppState State
@implements IDisposable

<div class="pane-scroll">
    <div class="pane-narrow">
        <div class="pane-head" style="padding-left:0;padding-right:0;">
            <h2><i class="bi bi-globe"></i> Community</h2>
            <span class="muted">Discover services published by other people's agents.</span>
        </div>

        <div class="tabs">
            <button class="tab @(tab == "discover" ? "on" : "")" @onclick='() => tab = "discover"'>Discover</button>
            <button class="tab @(tab == "mine" ? "on" : "")" @onclick='() => tab = "mine"'>My services</button>
        </div>

        @if (tab == "discover")
        {
            <div class="add-row">
                <input class="full" @bind="query" @bind:event="oninput" @onkeydown="OnSearchKey"
                       placeholder="Search services by name, description or category…" aria-label="Search services" />
                <button class="primary" @onclick="Search"><i class="bi bi-search"></i> Search</button>
            </div>

            <div class="cat-filter">
                <button class="cat-chip @(catFilter is null ? "on" : "")" @onclick="() => SetCatFilter(null)">All</button>
                @foreach (var c in ServiceCategories.All)
                {
                    <button class="cat-chip @(catFilter == c ? "on" : "")" @onclick="() => SetCatFilter(c)">@c</button>
                }
            </div>

            @if (loading)
            {
                <div class="empty">Loading services…</div>
            }
            else if (!FilteredResults.Any())
            {
                <div class="empty">
                    @(catFilter is null
                        ? "No services yet. Publish one from the My services tab."
                        : $"No {catFilter} services yet.")
                </div>
            }
            else
            {
                <div class="svc-list">
                    @foreach (var l in FilteredResults)
                    {
                        <div class="svc-card" @key="l.ServiceId">
                            <div class="svc-top">
                                <div class="svc-title">
                                    @l.Name
                                    @if (l.Verified)
                                    {
                                        <span class="svc-verified" title="Verified publisher"><i class="bi bi-patch-check-fill"></i> Verified</span>
                                    }
                                </div>
                                <span class="svc-cat">@l.Category</span>
                            </div>
                            <div class="svc-by">by @("@" + l.Handle)</div>
                            @if (!string.IsNullOrWhiteSpace(l.Description))
                            {
                                <div class="svc-desc">@l.Description</div>
                            }

                            <div class="svc-rep">
                                <span title="Upvotes"><i class="bi bi-hand-thumbs-up"></i> @l.Upvotes</span>
                                <span title="Downvotes"><i class="bi bi-hand-thumbs-down"></i> @l.Downvotes</span>
                                <span title="People who have used this"><i class="bi bi-people"></i> @l.UniqueUsers</span>
                                <span class="svc-score" title="Community ranking score"><i class="bi bi-graph-up-arrow"></i> ranked @l.Score.ToString("0.0")</span>
                            </div>

                            <div class="svc-vote">
                                <button class="ghost" title="Upvote" @onclick="() => Vote(l, 1)"><i class="bi bi-hand-thumbs-up"></i> Upvote</button>
                                <button class="ghost" title="Downvote" @onclick="() => Vote(l, -1)"><i class="bi bi-hand-thumbs-down"></i> Downvote</button>
                                @if (voteHints.TryGetValue(l.ServiceId, out var vh))
                                {
                                    <span class="svc-hint"><i class="bi bi-info-circle"></i> @vh</span>
                                }
                            </div>

                            <div class="svc-invoke">
                                <input class="full" value="@GetPrompt(l.ServiceId)"
                                       @oninput="e => prompts[l.ServiceId] = e.Value?.ToString() ?? string.Empty"
                                       @onkeydown="e => OnInvokeKey(e, l)"
                                       placeholder="Ask this service something…" aria-label="Prompt for @l.Name" />
                                <button class="primary" @onclick="() => Send(l)"
                                        disabled="@string.IsNullOrWhiteSpace(GetPrompt(l.ServiceId))">
                                    <i class="bi bi-send"></i> Send
                                </button>
                            </div>
                            @if (confirms.TryGetValue(l.ServiceId, out var cf))
                            {
                                <div class="svc-sent"><i class="bi bi-check-circle"></i> @cf</div>
                            }
                        </div>
                    }
                </div>
            }
        }
        else
        {
            <p class="hint">
                Publish a service to let anyone reach these capabilities through your agent. Only Knowledge,
                Skills and Widgets can be public - never your private connectors or device tools.
            </p>

            <div class="card-panel">
                <h3>Create a service</h3>
                <input class="full" @bind="newName" placeholder="Name (e.g. Travel planner)" aria-label="Service name" />
                <textarea class="full" rows="2" @bind="newDesc" placeholder="Description others will see" aria-label="Service description"></textarea>
                <select class="full" @bind="newCat" aria-label="Category">
                    @foreach (var c in ServiceCategories.All)
                    {
                        <option value="@c">@c</option>
                    }
                </select>
                <textarea class="full" rows="3" @bind="newPersona" placeholder="How should your service agent behave?" aria-label="Persona"></textarea>

                <div class="cap-pickers">
                    <div class="cap-pickers-head">
                        <span><i class="bi bi-unlock"></i> Exposed capabilities</span>
                        <span class="cap-summary">@CapSummary(newKnowledgeIds, newSkillIds, newWidgetIds)</span>
                    </div>
                    <span class="cap-note">Pick which of your items THIS service may use. Anything not selected stays private to it.</span>

                    <div class="cap-group">
                        <h4><i class="bi bi-journal-text"></i> Knowledge</h4>
                        <div class="chip-row">
                            @foreach (var k in State.Profile.Knowledge)
                            {
                                <label class="chip @(newKnowledgeIds.Contains(k.Id) ? "on" : "")" @key="k.Id">
                                    <input type="checkbox" checked="@newKnowledgeIds.Contains(k.Id)"
                                           @onchange="e => ToggleCap(newKnowledgeIds, k.Id, (bool)(e.Value ?? false))" />
                                    @(string.IsNullOrWhiteSpace(k.Title) ? "(untitled)" : k.Title)
                                </label>
                            }
                            @if (State.Profile.Knowledge.Count == 0)
                            {
                                <span class="empty-mini">No knowledge items yet.</span>
                            }
                        </div>
                    </div>

                    <div class="cap-group">
                        <h4><i class="bi bi-lightning-charge"></i> Skills</h4>
                        <div class="chip-row">
                            @foreach (var s in State.Profile.Skills)
                            {
                                <label class="chip @(newSkillIds.Contains(s.Id) ? "on" : "")" @key="s.Id">
                                    <input type="checkbox" checked="@newSkillIds.Contains(s.Id)"
                                           @onchange="e => ToggleCap(newSkillIds, s.Id, (bool)(e.Value ?? false))" />
                                    @(string.IsNullOrWhiteSpace(s.Name) ? "(unnamed)" : s.Name)
                                </label>
                            }
                            @if (State.Profile.Skills.Count == 0)
                            {
                                <span class="empty-mini">No skills yet.</span>
                            }
                        </div>
                    </div>

                    <div class="cap-group">
                        <h4><i class="bi bi-window-stack"></i> Widgets</h4>
                        <div class="chip-row">
                            @foreach (var w in State.Profile.Widgets)
                            {
                                <label class="chip @(newWidgetIds.Contains(w.Id) ? "on" : "")" @key="w.Id">
                                    <input type="checkbox" checked="@newWidgetIds.Contains(w.Id)"
                                           @onchange="e => ToggleCap(newWidgetIds, w.Id, (bool)(e.Value ?? false))" />
                                    @(string.IsNullOrWhiteSpace(w.Name) ? "(unnamed)" : w.Name)
                                </label>
                            }
                            @if (State.Profile.Widgets.Count == 0)
                            {
                                <span class="empty-mini">No widgets yet.</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="budget-row">
                    <label class="budget-field">
                        <span>Total budget (MTokens, lifetime)</span>
                        <input type="number" min="0" step="0.1" @bind="newTotalMt" aria-label="Total budget in MTokens" />
                    </label>
                    <label class="budget-field">
                        <span>Per person (MTokens, per day)</span>
                        <input type="number" min="0" step="0.1" @bind="newPerHandleMt" aria-label="Per-person daily budget in MTokens" />
                    </label>
                    <label class="budget-field">
                        <span>Requests / person / day</span>
                        <input type="number" min="0" step="1" @bind="newReqLimit" aria-label="Daily request limit per person" />
                    </label>
                </div>
                <div class="budget-hint"><i class="bi bi-info-circle"></i> 0 = unlimited. Total is a lifetime ceiling; per-person budget and request limit reset daily. The request limit stops abuse from cheap request floods.</div>

                <div class="form-actions">
                    <button class="primary" @onclick="Create" disabled="@string.IsNullOrWhiteSpace(newName)">
                        <i class="bi bi-plus-lg"></i> Create
                    </button>
                </div>
            </div>

            <div class="pane-head" style="padding-left:0;padding-right:0;">
                <h2><i class="bi bi-broadcast"></i> Your services</h2>
                <span class="muted">toggle Published to list or delist each service in the directory</span>
            </div>

            <div class="card-panel">
                @foreach (var svc in State.Profile.PublishedServices.ToList())
                {
                    var stat = StatFor(svc.Id);
                    <div class="svc-item @(editingId == svc.Id ? "editing" : "")" @key="svc.Id">
                        <div class="list-row">
                            <div class="row-main">
                                <div class="row-title">@svc.Name @(string.IsNullOrWhiteSpace(svc.Category) ? "" : $"· {svc.Category}")</div>
                                <div class="row-sub">@svc.Description</div>
                                @if (svc.TotalTokenBudget > 0 || svc.SpentTokens > 0)
                                {
                                    <div class="svc-budget" title="Tokens spent vs lifetime total budget">
                                        <div class="budget-bar">
                                            <div class="budget-fill @(svc.TotalTokenBudget > 0 && svc.SpentTokens >= svc.TotalTokenBudget ? "full" : "")" style="width:@(BudgetPct(svc))%"></div>
                                        </div>
                                        <span class="budget-label">@TokenFormat.SpentOfTotal(svc.SpentTokens, svc.TotalTokenBudget)</span>
                                    </div>
                                    <div class="svc-percap">
                                        <i class="bi bi-person"></i> @(svc.PerHandleTokenBudget > 0 ? $"{TokenFormat.ToMTokens(svc.PerHandleTokenBudget)} / person / day" : "unlimited per person")
                                        <span class="svc-percap-sep">·</span>
                                        <i class="bi bi-speedometer2"></i> @(svc.PerHandleDailyRequestLimit > 0 ? $"{svc.PerHandleDailyRequestLimit} requests / person / day" : "unlimited requests")
                                    </div>
                                }
                                @if (stat is not null)
                                {
                                    <div class="svc-rep" style="margin-top:6px;">
                                        <span title="Upvotes"><i class="bi bi-hand-thumbs-up"></i> @stat.Upvotes</span>
                                        <span title="Downvotes"><i class="bi bi-hand-thumbs-down"></i> @stat.Downvotes</span>
                                        <span title="People who have used this"><i class="bi bi-people"></i> @stat.UniqueUsers</span>
                                    </div>
                                }
                            </div>
                            <div class="row-actions">
                                <button class="icon-btn" title="Copy share link" aria-label="Copy share link" @onclick="() => CopyShareLink(svc)"><i class="bi bi-share"></i></button>
                                @if (copiedId == svc.Id)
                                {
                                    <span class="svc-copied"><i class="bi bi-check-lg"></i> Copied!</span>
                                }
                                <button class="icon-btn" title="Edit" aria-label="Edit service" @onclick="() => BeginEdit(svc)"><i class="bi bi-pencil"></i></button>
                                <button class="@(svc.Published ? "primary" : "ghost")" title="@(svc.Published ? "Delist from the directory" : "List in the directory")"
                                        @onclick="() => TogglePublish(svc, !svc.Published)">
                                    <i class="bi @(svc.Published ? "bi-broadcast" : "bi-broadcast-pin")"></i> @(svc.Published ? "Published" : "Publish")
                                </button>
                                <button class="icon-btn" title="Delete" aria-label="Delete service" @onclick="() => Delete(svc)"><i class="bi bi-trash"></i></button>
                            </div>
                        </div>
                        @if (editingId == svc.Id)
                        {
                            <div class="svc-edit">
                                <input class="full" @bind="editName" placeholder="Name" aria-label="Service name" />
                                <textarea class="full" rows="2" @bind="editDesc" placeholder="Description others will see" aria-label="Service description"></textarea>
                                <select class="full" @bind="editCat" aria-label="Category">
                                    @foreach (var c in ServiceCategories.All)
                                    {
                                        <option value="@c">@c</option>
                                    }
                                </select>
                                <textarea class="full" rows="3" @bind="editPersona" placeholder="How should your service agent behave?" aria-label="Persona"></textarea>

                                <div class="cap-pickers">
                                    <div class="cap-pickers-head">
                                        <span><i class="bi bi-unlock"></i> Exposed capabilities</span>
                                        <span class="cap-summary">@CapSummary(editKnowledgeIds, editSkillIds, editWidgetIds)</span>
                                    </div>
                                    <span class="cap-note">Pick which of your items THIS service may use. Anything not selected stays private to it.</span>

                                    <div class="cap-group">
                                        <h4><i class="bi bi-journal-text"></i> Knowledge</h4>
                                        <div class="chip-row">
                                            @foreach (var k in State.Profile.Knowledge)
                                            {
                                                <label class="chip @(editKnowledgeIds.Contains(k.Id) ? "on" : "")" @key="k.Id">
                                                    <input type="checkbox" checked="@editKnowledgeIds.Contains(k.Id)"
                                                           @onchange="e => ToggleCap(editKnowledgeIds, k.Id, (bool)(e.Value ?? false))" />
                                                    @(string.IsNullOrWhiteSpace(k.Title) ? "(untitled)" : k.Title)
                                                </label>
                                            }
                                            @if (State.Profile.Knowledge.Count == 0)
                                            {
                                                <span class="empty-mini">No knowledge items yet.</span>
                                            }
                                        </div>
                                    </div>

                                    <div class="cap-group">
                                        <h4><i class="bi bi-lightning-charge"></i> Skills</h4>
                                        <div class="chip-row">
                                            @foreach (var s in State.Profile.Skills)
                                            {
                                                <label class="chip @(editSkillIds.Contains(s.Id) ? "on" : "")" @key="s.Id">
                                                    <input type="checkbox" checked="@editSkillIds.Contains(s.Id)"
                                                           @onchange="e => ToggleCap(editSkillIds, s.Id, (bool)(e.Value ?? false))" />
                                                    @(string.IsNullOrWhiteSpace(s.Name) ? "(unnamed)" : s.Name)
                                                </label>
                                            }
                                            @if (State.Profile.Skills.Count == 0)
                                            {
                                                <span class="empty-mini">No skills yet.</span>
                                            }
                                        </div>
                                    </div>

                                    <div class="cap-group">
                                        <h4><i class="bi bi-window-stack"></i> Widgets</h4>
                                        <div class="chip-row">
                                            @foreach (var w in State.Profile.Widgets)
                                            {
                                                <label class="chip @(editWidgetIds.Contains(w.Id) ? "on" : "")" @key="w.Id">
                                                    <input type="checkbox" checked="@editWidgetIds.Contains(w.Id)"
                                                           @onchange="e => ToggleCap(editWidgetIds, w.Id, (bool)(e.Value ?? false))" />
                                                    @(string.IsNullOrWhiteSpace(w.Name) ? "(unnamed)" : w.Name)
                                                </label>
                                            }
                                            @if (State.Profile.Widgets.Count == 0)
                                            {
                                                <span class="empty-mini">No widgets yet.</span>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="budget-row">
                                    <label class="budget-field">
                                        <span>Total budget (MTokens, lifetime)</span>
                                        <input type="number" min="0" step="0.1" @bind="editTotalMt" aria-label="Total budget in MTokens" />
                                    </label>
                                    <label class="budget-field">
                                        <span>Per person (MTokens, per day)</span>
                                        <input type="number" min="0" step="0.1" @bind="editPerHandleMt" aria-label="Per-person daily budget in MTokens" />
                                    </label>
                                    <label class="budget-field">
                                        <span>Requests / person / day</span>
                                        <input type="number" min="0" step="1" @bind="editReqLimit" aria-label="Daily request limit per person" />
                                    </label>
                                </div>
                                <div class="budget-hint"><i class="bi bi-info-circle"></i> 0 = unlimited. Total cannot go below the @TokenFormat.ToMTokens(svc.SpentTokens) already spent.</div>
                                <div class="form-actions">
                                    <button class="ghost" @onclick="CancelEdit"><i class="bi bi-x-lg"></i> Cancel</button>
                                    <button class="primary" @onclick="() => SaveEdit(svc)" disabled="@string.IsNullOrWhiteSpace(editName)"><i class="bi bi-check-lg"></i> Save</button>
                                </div>
                            </div>
                        }
                    </div>
                }
                @if (State.Profile.PublishedServices.Count == 0)
                {
                    <div class="empty">No services yet. Create one above, then toggle Published to list it.</div>
                }
            </div>
        }
    </div>
</div>

@code {
    string tab = "discover";

    // Discover state
    string query = "";
    bool loading = true;
    List<ServiceListing> results = new();
    string? catFilter;
    readonly Dictionary<string, string> prompts = new();
    readonly Dictionary<string, string> confirms = new();
    readonly Dictionary<string, string> voteHints = new();

    // Results narrowed to the selected category chip (client-side; the text search is server-side).
    IEnumerable<ServiceListing> FilteredResults =>
        catFilter is null
            ? results
            : results.Where(r => string.Equals(r.Category, catFilter, StringComparison.OrdinalIgnoreCase));

    // Create-service form state (defaults: 1.0 MTokens lifetime total, 0.1 MTokens per person per day)
    string newName = "";
    string newDesc = "";
    string newCat = ServiceCategories.Fallback;
    string newPersona = "";
    double newTotalMt = 1.0;
    double newPerHandleMt = 0.1;
    int newReqLimit = 100;

    // Per-service capability selections for the create form (ids of items THIS new service may use).
    readonly HashSet<string> newKnowledgeIds = new(StringComparer.Ordinal);
    readonly HashSet<string> newSkillIds = new(StringComparer.Ordinal);
    readonly HashSet<string> newWidgetIds = new(StringComparer.Ordinal);

    // Inline edit state (null when no service is being edited).
    string? editingId;
    string editName = "";
    string editDesc = "";
    string editCat = ServiceCategories.Fallback;
    string editPersona = "";
    double editTotalMt;
    double editPerHandleMt;
    int editReqLimit;

    // Per-service capability selections for the inline edit panel, seeded from the service in BeginEdit.
    readonly HashSet<string> editKnowledgeIds = new(StringComparer.Ordinal);
    readonly HashSet<string> editSkillIds = new(StringComparer.Ordinal);
    readonly HashSet<string> editWidgetIds = new(StringComparer.Ordinal);

    // Transient: id of the service whose share link was just copied (drives the inline "Copied!" hint).
    string? copiedId;

    // Best-effort live stats for the owner's own services, keyed by ServiceId.
    readonly Dictionary<string, ServiceListing> statsById = new(StringComparer.Ordinal);

    protected override void OnInitialized() => State.Changed += Refresh;

    protected override async Task OnInitializedAsync()
    {
        await Search();
        await RefreshStats();
    }

    void Refresh() => InvokeAsync(StateHasChanged);

    // ---- Discover ----
    string GetPrompt(string id) => prompts.TryGetValue(id, out var p) ? p : "";

    void OnSearchKey(KeyboardEventArgs e) { if (e.Key == "Enter") _ = Search(); }

    void OnInvokeKey(KeyboardEventArgs e, ServiceListing l) { if (e.Key == "Enter") _ = Send(l); }

    void SetCatFilter(string? c) { catFilter = c; StateHasChanged(); }

    async Task Search()
    {
        loading = true;
        StateHasChanged();
        var q = string.IsNullOrWhiteSpace(query) ? null : query.Trim();
        var list = await Dir.BrowseAsync(q);
        results = list.ToList();
        loading = false;
        StateHasChanged();
    }

    async Task RefreshStats()
    {
        var list = await Dir.BrowseAsync(null);
        statsById.Clear();
        foreach (var l in list) statsById[l.ServiceId] = l;
        StateHasChanged();
    }

    async Task Send(ServiceListing l)
    {
        var prompt = GetPrompt(l.ServiceId).Trim();
        if (string.IsNullOrWhiteSpace(prompt)) return;

        // Open (or reuse) the service thread, append my prompt, and send it with transcript context.
        var conv = State.GetOrCreateServiceConversation(l.Handle, l.ServiceId, l.Name);
        State.AddChatLine(conv.Handle, new ChatLine { Role = "assistant", Text = prompt, Via = "agent", AddressedToAgent = true, Status = "sent" });
        await Mesh.SendServiceRequestAsync(conv);
        await Dir.ReportUsedAsync(l.ServiceId);

        prompts[l.ServiceId] = "";
        confirms[l.ServiceId] = "Sent. Continue the conversation in Messages.";
        StateHasChanged();
    }

    async Task Vote(ServiceListing l, int vote)
    {
        var ok = await Dir.VoteAsync(l.ServiceId, vote);
        if (!ok)
        {
            voteHints[l.ServiceId] = "Vote after you have used a service.";
            StateHasChanged();
            return;
        }

        voteHints.Remove(l.ServiceId);
        var updated = await Dir.GetAsync(l.ServiceId);
        if (updated is not null)
        {
            var idx = results.IndexOf(l);
            if (idx >= 0) results[idx] = updated;
            statsById[updated.ServiceId] = updated;
        }
        StateHasChanged();
    }

    // ---- My services ----
    ServiceListing? StatFor(string id) => statsById.TryGetValue(id, out var s) ? s : null;

    // Percentage of the total budget consumed (0 when the budget is unlimited).
    static int BudgetPct(PublishedService svc)
    {
        if (svc.TotalTokenBudget <= 0) return 0;
        var pct = (int)Math.Round(100.0 * svc.SpentTokens / svc.TotalTokenBudget);
        return Math.Clamp(pct, 0, 100);
    }

    void BeginEdit(PublishedService svc)
    {
        editingId = svc.Id;
        editName = svc.Name;
        editDesc = svc.Description;
        editCat = ServiceCategories.Coerce(svc.Category);
        editPersona = svc.Persona;
        editTotalMt = TokenFormat.ToMTokensValue(svc.TotalTokenBudget);
        editPerHandleMt = TokenFormat.ToMTokensValue(svc.PerHandleTokenBudget);
        editReqLimit = svc.PerHandleDailyRequestLimit;
        editKnowledgeIds.Clear();
        editKnowledgeIds.UnionWith(svc.KnowledgeIds);
        editSkillIds.Clear();
        editSkillIds.UnionWith(svc.SkillIds);
        editWidgetIds.Clear();
        editWidgetIds.UnionWith(svc.WidgetIds);
        StateHasChanged();
    }

    void CancelEdit() => editingId = null;

    void Create()
    {
        if (string.IsNullOrWhiteSpace(newName)) return;
        State.Mutate(p => p.PublishedServices.Add(new PublishedService
        {
            Name = newName.Trim(),
            Description = newDesc.Trim(),
            Category = ServiceCategories.Coerce(newCat),
            Persona = newPersona.Trim(),
            TotalTokenBudget = TokenFormat.FromMTokens(newTotalMt),
            PerHandleTokenBudget = TokenFormat.FromMTokens(newPerHandleMt),
            PerHandleDailyRequestLimit = Math.Max(0, newReqLimit),
            KnowledgeIds = newKnowledgeIds.ToList(),
            SkillIds = newSkillIds.ToList(),
            WidgetIds = newWidgetIds.ToList()
        }));
        newName = "";
        newDesc = "";
        newCat = ServiceCategories.Fallback;
        newPersona = "";
        newTotalMt = 1.0;
        newPerHandleMt = 0.1;
        newReqLimit = 100;
        newKnowledgeIds.Clear();
        newSkillIds.Clear();
        newWidgetIds.Clear();
    }

    async Task SaveEdit(PublishedService svc)
    {
        if (string.IsNullOrWhiteSpace(editName)) return;
        var name = editName.Trim();
        var desc = editDesc.Trim();
        var cat = ServiceCategories.Coerce(editCat);
        var persona = editPersona.Trim();
        var total = TokenFormat.FromMTokens(editTotalMt);
        var perHandle = TokenFormat.FromMTokens(editPerHandleMt);
        // A total budget can be raised but never dropped below what has already been spent.
        if (total > 0 && total < svc.SpentTokens) total = svc.SpentTokens;

        State.Mutate(_ =>
        {
            svc.Name = name;
            svc.Description = desc;
            svc.Category = cat;
            svc.Persona = persona;
            svc.TotalTokenBudget = total;
            svc.PerHandleTokenBudget = perHandle;
            svc.PerHandleDailyRequestLimit = Math.Max(0, editReqLimit);
            svc.KnowledgeIds = editKnowledgeIds.ToList();
            svc.SkillIds = editSkillIds.ToList();
            svc.WidgetIds = editWidgetIds.ToList();
        });
        // Propagate metadata changes to the live directory listing when published.
        if (svc.Published)
        {
            await Dir.PublishAsync(svc);
            await RefreshStats();
        }
        editingId = null;
    }

    async Task TogglePublish(PublishedService svc, bool on)
    {
        if (on)
        {
            var ok = await Dir.PublishAsync(svc);
            if (ok) State.Mutate(_ => svc.Published = true);
        }
        else
        {
            await Dir.UnpublishAsync(svc.Id);
            State.Mutate(_ => svc.Published = false);
        }
        await RefreshStats();
    }

    async Task Delete(PublishedService svc)
    {
        if (editingId == svc.Id) editingId = null;
        await Dir.UnpublishAsync(svc.Id);
        State.Mutate(p => p.PublishedServices.Remove(svc));
        await RefreshStats();
    }

    // ---- Per-service capability pickers ----
    // Toggles one capability id in a selection set (used by both the create form and the edit panel).
    void ToggleCap(HashSet<string> set, string id, bool on)
    {
        if (on) set.Add(id);
        else set.Remove(id);
        StateHasChanged();
    }

    // A short "N knowledge, N skills, N widgets exposed" summary for a selection.
    static string CapSummary(HashSet<string> knowledge, HashSet<string> skills, HashSet<string> widgets)
    {
        static string Pluralize(int n, string noun) => $"{n} {noun}{(n == 1 ? "" : "s")}";
        return $"{knowledge.Count} knowledge, {Pluralize(skills.Count, "skill")}, {Pluralize(widgets.Count, "widget")} exposed";
    }

    // Copies the public web share link for a service and briefly shows a "Copied!" confirmation.
    async Task CopyShareLink(PublishedService svc)
    {
        var link = global::Mesh.Shared.UniversalLink.ForService(State.Profile.Handle, svc.Id);
        await Microsoft.Maui.ApplicationModel.DataTransfer.Clipboard.Default.SetTextAsync(link);
        copiedId = svc.Id;
        StateHasChanged();
        await Task.Delay(2000);
        if (copiedId == svc.Id)
        {
            copiedId = null;
            StateHasChanged();
        }
    }

    public void Dispose() => State.Changed -= Refresh;
}
