@inject AppState State
@implements IDisposable

@{
    var t = State.Profile.Tokens;
    // Always label with the CURRENTLY selected model, not the stored key (which is only the
    // reset trigger and can lag behind a model switch until the next token is recorded).
    var modelKey = State.CurrentModelKey();
    var tip = $"{modelKey}\nPrompt {TokenFormat.ToMTokens(t.PromptTokens)} + Completion {TokenFormat.ToMTokens(t.CompletionTokens)} = {TokenFormat.ToMTokens(t.TotalTokens)}";
}

@if (Compact)
{
    <span class="tm-pill" title="@tip">
        <span class="tm-bar" aria-hidden="true">▮</span>
        <span class="tm-pill-count">@TokenFormat.ToMTokensValue(t.TotalTokens).ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)</span>
        <span class="tm-pill-unit">MTokens</span>
    </span>
}
else
{
    <div class="tm-card">
        <div class="tm-head">
            <span class="tm-title">Tokens this model</span>
            <span class="tm-model" title="@modelKey">@modelKey</span>
        </div>
        <div class="tm-total">@TokenFormat.ToMTokens(t.TotalTokens)</div>
        <div class="tm-breakdown">
            <span class="tm-chip"><span class="tm-chip-label">Prompt</span> @TokenFormat.ToMTokens(t.PromptTokens)</span>
            <span class="tm-chip"><span class="tm-chip-label">Completion</span> @TokenFormat.ToMTokens(t.CompletionTokens)</span>
        </div>
    </div>
}

@code {
    [Parameter] public bool Compact { get; set; }

    protected override void OnInitialized()
    {
        State.Changed += Refresh;
    }

    void Refresh() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        State.Changed -= Refresh;
    }
}
