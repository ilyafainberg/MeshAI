@inject MeshClient Mesh

@* Reusable "Report AI content" dialog (Microsoft Store Policy 11.16). Shows the EXACT transcript and
   metadata that will be sent, and gates submission behind an explicit consent checkbox. Call Show(...). *@
@if (open)
{
    <div class="report-scrim" @onclick="Cancel">
        <div class="report-modal" @onclick:stopPropagation="true" role="dialog" aria-modal="true" aria-label="Report AI content">
            <h3><i class="bi bi-flag"></i> Report AI content</h3>
            @if (sent)
            {
                <div class="report-done"><i class="bi bi-check-circle"></i> Thanks. Your report was sent to Mesh for review.</div>
            }
            else
            {
                <p class="report-intro">Report inappropriate content generated by the AI. Everything shown below will be sent to Mesh for review.</p>

                <label class="report-field">
                    <span>What is wrong?</span>
                    <select @bind="category" aria-label="Report category">
                        @foreach (var c in Categories)
                        {
                            <option value="@c">@c</option>
                        }
                    </select>
                </label>

                <label class="report-field">
                    <span>Add a note (optional)</span>
                    <textarea rows="2" @bind="note" placeholder="Anything that helps us review this" aria-label="Report note"></textarea>
                </label>

                <div class="report-preview">
                    <div class="report-preview-head"><i class="bi bi-eye"></i> Exactly what will be shared</div>
                    <div class="report-meta">
                        <div><b>About:</b> @target</div>
                        @if (!string.IsNullOrWhiteSpace(model)) { <div><b>Model:</b> @model</div> }
                        <div><b>Category:</b> @category</div>
                        @if (!string.IsNullOrWhiteSpace(note)) { <div><b>Note:</b> @note</div> }
                    </div>
                    @if (transcript.Count == 0)
                    {
                        <div class="report-empty">No messages to include.</div>
                    }
                    else
                    {
                        <div class="report-transcript">
                            @foreach (var l in transcript)
                            {
                                <div class="report-line"><b>@l.Author:</b> @l.Text</div>
                            }
                        </div>
                    }
                </div>

                <label class="report-consent">
                    <input type="checkbox" @bind="consent" />
                    <span>I understand and agree to share the messages shown above with Mesh for review.</span>
                </label>

                <div class="report-actions">
                    <button class="ghost" @onclick="Cancel" disabled="@sending">Cancel</button>
                    <button class="primary" @onclick="Submit" disabled="@(!consent || sending)">
                        <i class="bi bi-send"></i> @(sending ? "Sending…" : "Submit report")
                    </button>
                </div>
            }
        </div>
    </div>
}

@code {
    static readonly string[] Categories = { "Harmful or dangerous", "Hateful", "Sexual", "Violent", "Harassment", "Other" };

    bool open, consent, sending, sent;
    string category = "Harmful or dangerous";
    string note = "";
    string target = "";
    string? model;
    string? serviceId;
    List<ReportLine> transcript = new();

    /// <summary>
    /// Opens the report dialog for the given context. <paramref name="authorOf"/> maps each chat line
    /// to a display author (the caller knows the role convention for its screen). Only the last ~20
    /// lines are included. <paramref name="modelLabel"/> is shown so the user sees what is disclosed.
    /// </summary>
    public void Show(string target, IEnumerable<ChatLine> lines, Func<ChatLine, string> authorOf,
        string? modelLabel = null, string? serviceId = null)
    {
        this.target = target;
        this.model = modelLabel;
        this.serviceId = serviceId;
        transcript = lines
            .Where(l => !string.IsNullOrWhiteSpace(l.Text))
            .TakeLast(20)
            .Select(l => new ReportLine(authorOf(l), l.Text))
            .ToList();
        category = Categories[0];
        note = "";
        consent = false;
        sent = false;
        sending = false;
        open = true;
        StateHasChanged();
    }

    void Cancel()
    {
        if (sending) return;
        open = false;
        StateHasChanged();
    }

    async Task Submit()
    {
        if (!consent || sending) return;
        sending = true;
        StateHasChanged();
        var ok = await Mesh.SendReportAsync(target, category, note, serviceId, transcript);
        sending = false;
        sent = ok;
        StateHasChanged();
        if (ok)
        {
            await Task.Delay(1600);
            open = false;
            StateHasChanged();
        }
    }
}
